// ‚ĒÄ‚ĒÄ‚ĒÄ GROUP: GENERAL SETTINGS ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
var GRP_GENERAL = "‚öôÔłŹ GENERAL SETTINGS"

i_tradingMode     = input.string("Swing Trading", "Trading Mode",
     options = ["Day Trading", "Swing Trading", "Position Trading"],
     group   = GRP_GENERAL,
     tooltip = "Day: balanced TP/SL for short holds (1H-4H charts). Swing: wide TP/SL, recommended for 1H+ crypto. Position: very wide, long-hold bias (4H+ / Daily).")

i_marketType      = input.string("Futures", "Market Type",
     options = ["Spot", "Futures", "Both"],
     group   = GRP_GENERAL,
     tooltip = "Spot: hanya LONG/BUY (no short). Futures: LONG & SHORT. Both: keduanya aktif. Menentukan apakah shortCondition dieksekusi.")

i_riskMode        = input.string("Balanced", "Risk Profile",
     options = ["Conservative", "Balanced", "Aggressive"],
     group   = GRP_GENERAL,
     tooltip = "Conservative: minConfluence +2 (lebih selektif). Balanced: sesuai setting. Aggressive: minConfluence -1 (lebih sensitif).")

i_riskPercent     = input.float(1.0, "Account Risk Per Trade (%)",
     minval  = 0.1,
     maxval  = 10.0,
     step    = 0.1,
     group   = GRP_GENERAL,
     tooltip = "Persentase akun yang dirisiko per satu trade. Contoh: 1% dari $10.000 = $100 risiko per trade.")

i_accountSize     = input.float(10000.0, "Account Size (USD)",
     minval  = 100.0,
     step    = 100.0,
     group   = GRP_GENERAL,
     tooltip = "Total ukuran akun dalam USD. Digunakan bersama 'Account Risk Per Trade (%)' untuk menghitung position sizing otomatis.")

i_leverage        = input.int(1, "Max Leverage for Position Sizing",
     minval  = 1,
     maxval  = 20,
     step    = 1,
     group   = GRP_GENERAL,
     tooltip = "‚ö†ÔłŹ CRITICAL: Maximum leverage yang akan digunakan untuk position sizing calculation.\n" +
               "‚ÄĘ 1 = No leverage (Spot Trading) - AMAN untuk spot market\n" +
               "‚ÄĘ 3 = Conservative leverage - untuk trader berpengalaman\n" +
               "‚ÄĘ 5 = Moderate leverage (default untuk futures)\n" +
               "‚ÄĘ 10+ = Aggressive/High leverage - SANGAT BERISIKO!\n\n" +
               "PERINGATAN: Leverage meningkatkan profit DAN loss secara eksponensial. " +
               "Higher leverage = higher liquidation risk. Gunakan dengan sangat hati-hati!")

i_showDashboard   = input.bool(true,  "Show Dashboard",                group = GRP_GENERAL)
i_showLabels      = input.bool(true,  "Show Signal Labels",            group = GRP_GENERAL)
i_showFib         = input.bool(true,  "Show Fibonacci Levels",         group = GRP_GENERAL)
i_showOrderBlocks = input.bool(true,  "Show Order Blocks",             group = GRP_GENERAL)
i_showMarketStr   = input.bool(true,  "Show Market Structure Labels",  group = GRP_GENERAL)

i_showFVG         = input.bool(true, "Show Fair Value Gap (FVG) Boxes",
     group   = GRP_GENERAL,
     tooltip = "Menampilkan kotak imbalance (FVG) dari 3-candle gaps. Hijau=bullish FVG, Merah=bearish FVG. Memudar saat harga masuk (mitigated).")

i_showLiqSweep    = input.bool(true, "Show Liquidity Sweep Labels",
     group   = GRP_GENERAL,
     tooltip = "Mendeteksi stop-hunt: harga spike melampaui swing H/L lalu berbalik tajam. Sinyal reversal kuat.")

// ‚ĒÄ‚ĒÄ‚ĒÄ GROUP: AUTO-TIMEFRAME ADAPTATION ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
var GRP_AUTO = "ūüĒĄ AUTO-TIMEFRAME ADAPTATION"

i_autoAdapt       = input.bool(true, "Enable Auto-Timeframe Adaptation",
     group   = GRP_AUTO,
     tooltip = "ūüĒ• Indicator otomatis menyesuaikan HTF, EMA periods, swing length, dan minConfluence berdasarkan chart timeframe aktif. Sangat direkomendasikan.")

i_autoAdjustEMA   = input.bool(true, "Auto-Adjust EMA Periods",
     group   = GRP_AUTO,
     tooltip = "Otomatis scale EMA 8/21/50/200 sesuai timeframe untuk optimal trend detection. Nonaktifkan jika ingin menggunakan EMA manual.")

i_autoAdjustAgg   = input.bool(true, "Auto-Adjust Aggressiveness (Swing Length & Min Confluence)",
     group   = GRP_AUTO,
     tooltip = "TF rendah (1m-5m): sensitivity tinggi (swing tight). TF tinggi (4H-Daily): sensitivity rendah (swing wide). Berpengaruh pada swing length dan minConfluence.")

// ‚ĒÄ‚ĒÄ‚ĒÄ GROUP: MULTI-TIMEFRAME ANALYSIS ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
var GRP_MTF = "ūüēź MULTI-TIMEFRAME ANALYSIS"

i_htf1            = input.timeframe("60",  "Higher Timeframe 1 (HTF1 ‚ÄĒ Manual)",
     group   = GRP_MTF,
     tooltip = "HTF1 manual (default: 1H). Diabaikan jika 'Auto-Timeframe Adaptation' aktif.")

i_htf2            = input.timeframe("240", "Higher Timeframe 2 (HTF2 ‚ÄĒ Manual)",
     group   = GRP_MTF,
     tooltip = "HTF2 manual (default: 4H). Diabaikan jika 'Auto-Timeframe Adaptation' aktif.")

i_htf3            = input.timeframe("D",   "Higher Timeframe 3 (HTF3 ‚ÄĒ Manual)",
     group   = GRP_MTF,
     tooltip = "HTF3 manual (default: 1D). Diabaikan jika 'Auto-Timeframe Adaptation' aktif.")

i_mtfWeight       = input.int(2, "MTF Confluence Weight",
     minval  = 1,
     maxval  = 2,
     group   = GRP_MTF,
     tooltip = "Bobot kontribusi MTF alignment ke total confluence score. Max contribution dibatasi 4 poin.")

i_reqMTFAlign     = input.bool(false, "Require Full MTF Alignment for Entry",
     group   = GRP_MTF,
     tooltip = "Jika true: entry hanya ketika SEMUA HTF aligned searah. Lebih selektif, lebih sedikit sinyal.")

// ‚ĒÄ‚ĒÄ‚ĒÄ GROUP: EMA RIBBON & TREND ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
var GRP_EMA = "ūüďą EMA RIBBON & TREND"

i_showEmaRibbon   = input.bool(true,  "Show EMA Ribbon", group = GRP_EMA)

i_ema8            = input.int(8,   "EMA Fast (Manual)",
     minval  = 2,
     group   = GRP_EMA,
     tooltip = "EMA cepat. Digunakan jika 'Auto-Adjust EMA Periods' dinonaktifkan.")

i_ema21           = input.int(21,  "EMA Mid (Manual)",
