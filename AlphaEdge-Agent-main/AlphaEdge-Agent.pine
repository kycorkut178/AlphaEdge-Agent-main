//@version=6
strategy(
title                = "AlphaEdge ‚ÄĒ Crypto Swing Strategy",
shorttitle           = "AE",
overlay              = true,
max_labels_count     = 500,
max_lines_count      = 500,
max_boxes_count      = 500,
default_qty_type  = strategy.fixed, // Changed from strategy.percent_of_equity to allow calcPositionSize full control
default_qty_value = 1,              // Set to 1 as qty is now calculated by calcPositionSize
initial_capital   = 1000,           // More realistic value for backtesting
commission_type      = strategy.commission.percent,
commission_value     = 0.05,
slippage             = 2,
calc_on_every_tick   = true,
max_bars_back        = 500
)

