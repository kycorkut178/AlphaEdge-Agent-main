// ‚ĒÄ‚ĒÄ‚ĒÄ GROUP: ICHIMOKU CLOUD (Full 5-Component) ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
var GRP_ICHI = "‚ėĀÔłŹ ICHIMOKU CLOUD (Full 5-Component)"

i_showIchimoku    = input.bool(true, "Show Ichimoku Cloud", group = GRP_ICHI)

i_showChikou      = input.bool(true, "Show Chikou Span (Lagging Line)",
