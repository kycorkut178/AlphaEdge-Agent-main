// ============================================================================
// ‚ö° AUTO-TIMEFRAME ADAPTATION FUNCTIONS ‚ö°
// ============================================================================

// ‚ĒÄ‚ĒÄ Helper: Timeframe in minutes ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
getTFMinutes() =>
    timeframe.in_seconds() / 60.0

// ‚ĒÄ‚ĒÄ Helper: Categorize current chart timeframe ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
getTFCategory() =>
    tf_min = getTFMinutes()
    if tf_min <= 1
        "1m"
    else if tf_min <= 5
        "5m"
    else if tf_min <= 15
        "15m"
    else if tf_min <= 60
        "1H"
    else if tf_min <= 240
        "4H"
    else if tf_min <= 1440
        "1D"
    else if tf_min <= 10080
        "1W"
    else
        "1M+"

// ‚ĒÄ‚ĒÄ Auto-select HTF1 (‚Čą 4√ó current TF, first higher frame) ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
getAutoHTF1() =>
    if not i_autoAdapt
        i_htf1
    else
        cat = getTFCategory()
        if cat == "1m" or cat == "5m" or cat == "15m"
            "60"    // ‚Üí 1H
        else if cat == "1H"
            "240"   // ‚Üí 4H
        else if cat == "4H"
            "D"     // ‚Üí 1D
        else if cat == "1D"
            "W"     // ‚Üí 1W
        else
            "M"     // ‚Üí 1M (1W and 1M+ both resolve to Monthly)

// ‚ĒÄ‚ĒÄ Auto-select HTF2 (‚Čą 16√ó current TF, second higher frame) ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
getAutoHTF2() =>
    if not i_autoAdapt
        i_htf2
    else
        cat = getTFCategory()
        if cat == "1m" or cat == "5m" or cat == "15m"
            "240"   // ‚Üí 4H
        else if cat == "1H"
            "D"     // ‚Üí 1D
        else if cat == "4H"
            "W"     // ‚Üí 1W
        else if cat == "1D"
            "M"     // ‚Üí 1M
        else
            "M"     // ‚Üí 1M (1W and above)

// ‚ĒÄ‚ĒÄ Auto-select HTF3 (‚Čą 64√ó current TF, third higher frame) ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
getAutoHTF3() =>
    if not i_autoAdapt
        i_htf3
    else
        cat = getTFCategory()
        if cat == "1m" or cat == "5m" or cat == "15m"
            "D"     // ‚Üí 1D
        else if cat == "1H"
            "W"     // ‚Üí 1W
        else if cat == "4H"
            "M"     // ‚Üí 1M
        else
            "M"     // Daily and above ‚Üí Monthly

// ‚ĒÄ‚ĒÄ Resolve actual HTF values (auto or manual) ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
autoHTF1 = getAutoHTF1()
autoHTF2 = getAutoHTF2()
autoHTF3 = getAutoHTF3()

htf1Actual = i_autoAdapt ? autoHTF1 : i_htf1
htf2Actual = i_autoAdapt ? autoHTF2 : i_htf2
htf3Actual = i_autoAdapt ? autoHTF3 : i_htf3

// ‚ĒÄ‚ĒÄ Auto-adjust EMA Fast (EMA8 equivalent) ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
getAutoEMA8() =>
    if not i_autoAdjustEMA
        i_ema8
    else
        cat = getTFCategory()
        if cat == "1m" or cat == "5m"
            5   // Very fast for scalping
        else if cat == "15m"
            8   // Fast intraday
        else if cat == "1H"
            13  // Standard swing fast
        else if cat == "4H"
            21  // Medium swing
        else if cat == "1D"
            34  // Position slow
        else
            34  // Weekly/Monthly: same as Daily

// ‚ĒÄ‚ĒÄ Auto-adjust EMA Mid (EMA21 equivalent) ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
getAutoEMA21() =>
    if not i_autoAdjustEMA
        i_ema21
    else
        cat = getTFCategory()
        if cat == "1m" or cat == "5m"
            13
        else if cat == "15m"
            21
        else if cat == "1H"
            50
        else if cat == "4H"
            89
        else if cat == "1D"
            144
        else
            200  // Weekly/Monthly: same as Daily

// ‚ĒÄ‚ĒÄ Auto-adjust EMA Slow (EMA50 equivalent) ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
getAutoEMA50() =>
    if not i_autoAdjustEMA
        i_ema50
    else
        cat = getTFCategory()
        if cat == "1m" or cat == "5m"
            34
        else if cat == "15m"
            55
        else if cat == "1H"
            100
        else if cat == "4H"
            150
        else if cat == "1D"
            200
        else
            200  // Weekly/Monthly: same as Daily

// ‚ĒÄ‚ĒÄ Auto-adjust EMA Trend (EMA200 equivalent) ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
getAutoEMA200() =>
    if not i_autoAdjustEMA
        i_ema200
    else
        cat = getTFCategory()
        if cat == "1m" or cat == "5m"
            89
        else if cat == "15m"
            144
        else if cat == "1H"
            200
        else if cat == "4H"
            200  // 4H: 200 is still the standard trend EMA
        else if cat == "1D"
            200
        else
            200  // Weekly/Monthly: 200 remains the gold standard

// ‚ĒÄ‚ĒÄ Auto-adjust Swing Detection Length ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
getAutoSwingLen(manualSwing) =>
    manualSwingInt = int(manualSwing)
    if not i_autoAdjustAgg
        manualSwingInt
    else
        cat = getTFCategory()
        if cat == "1m" or cat == "5m"
            3   // Tight for fast TFs
        else if cat == "15m"
            5   // Medium tight
        else if cat == "1H"
            10  // Standard swing (recommended)
        else if cat == "4H"
            15  // Wider for 4H
        else if cat == "1D"
            20  // Very wide for daily
        else
            20  // Weekly/Monthly: same as Daily

// ‚ĒÄ‚ĒÄ Auto-adjust Minimum Confluence Threshold ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
// Returns the higher of: TF-based baseline OR user-defined manual floor.
// This ensures auto-adapt can only raise the bar, never lower it below user intent
// (unless Aggressive mode is active, which may subtract 1 in the caller).
getAutoMinConfl(manualConfl) =>
    if not i_autoAdjustAgg
        manualConfl
    else
        cat    = getTFCategory()
        tfBase = cat == "1m" or cat == "5m" ? 4 :
                 cat == "15m"               ? 5 :
                 cat == "1H"                ? 7 :
                 cat == "4H"                ? 8 : 9
        math.max(tfBase, manualConfl)

// ‚ĒÄ‚ĒÄ Adaptive Label Size (used by Visualization & Functions) ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
// Returns label size based on chart timeframe:
// Daily+ ‚Üí normal, 4H ‚Üí small, 1H ‚Üí small, sub-1H ‚Üí tiny
adaptiveSize() =>
    sec = timeframe.in_seconds()
    sec >= 86400 ? size.normal : sec >= 14400 ? size.small : sec >= 3600 ? size.small : size.tiny

adaptiveSizeVal = adaptiveSize()

// ‚ĒÄ‚ĒÄ Timeframe to Label Converter (human-readable format) ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
tfToLabel(tf) =>
    result = tf
    if tf == "1"
        result := "1m"
    else if tf == "5"
        result := "5m"
    else if tf == "15"
        result := "15m"
    else if tf == "30"
        result := "30m"
    else if tf == "60"
        result := "1H"
    else if tf == "120"
        result := "2H"
    else if tf == "180"
        result := "3H"
    else if tf == "240"
        result := "4H"
    else if tf == "360"
        result := "6H"
    else if tf == "480"
        result := "8H"
    else if tf == "D"
        result := "1D"
    else if tf == "W"
        result := "1W"
    else if tf == "M"
        result := "1M"
    result
        
// ============================================================================
// ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēó   ‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚Ėą‚ēó   ‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚Ėą‚ēó   ‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó
// ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēź‚ēź‚ēĚ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚Ėą‚Ėą‚ēó  ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēź‚ēź‚ēĚ‚ēö‚ēź‚ēź‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēĚ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēź‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚Ėą‚Ėą‚ēó  ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēź‚ēź‚ēĚ
// ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó  ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĒ‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ        ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĒ‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó
// ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēĚ  ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ‚ēö‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ        ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ‚ēö‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĎ‚ēö‚ēź‚ēź‚ēź‚ēź‚Ėą‚Ėą‚ēĎ
// ‚Ėą‚Ėą‚ēĎ     ‚ēö‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ‚Ėą‚Ėą‚ēĎ ‚ēö‚Ėą‚Ėą‚Ėą‚Ėą‚ēĎ‚ēö‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó   ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ‚ēö‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ‚Ėą‚Ėą‚ēĎ ‚ēö‚Ėą‚Ėą‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĎ
// ‚ēö‚ēź‚ēĚ      ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ ‚ēö‚ēź‚ēĚ  ‚ēö‚ēź‚ēź‚ēź‚ēĚ ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ   ‚ēö‚ēź‚ēĚ   ‚ēö‚ēź‚ēĚ ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ ‚ēö‚ēź‚ēĚ  ‚ēö‚ēź‚ēź‚ēź‚ēĚ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ
//  GRUB 2 ‚ÄĒ FUNCTIONS (v6.5.0 ‚ÄĒ Fixed, Upgraded, Perfected)
// ============================================================================

// ‚ĒÄ‚ĒÄ‚ĒÄ Helper: Trading Mode ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
modeDay      = i_tradingMode == "Day Trading"
modeSwing    = i_tradingMode == "Swing Trading"
modePosition = i_tradingMode == "Position Trading"

// SL ATR multiplier by mode
atrModeMultSL = i_slATRMult

// Base TP R:R ratios by mode
tp1Base = modeDay ? 1.5 : modePosition ? 2.5 : i_tp1RR
tp2Base = modeDay ? 2.5 : modePosition ? 4.0 : i_tp2RR
tp3Base = modeDay ? 3.5 : modePosition ? 6.0 : i_tp3RR

// ‚ĒÄ‚ĒÄ‚ĒÄ [v6] Dynamic RR: ATR-based volatility scaling ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
// Scale TP targets upward when current volatility exceeds the 50-bar average.
// Range: 1.0√ó (normal vol) ‚Üí 1.5√ó (high vol). Capped to prevent over-extension.
atrVal  = ta.atr(i_atrPeriod)
atrPercent = atrVal / math.max(close, 0.000001) * 100.0
atrAvgPct  = ta.sma(atrPercent, 50)
atrRatio   = atrPercent / math.max(atrAvgPct, 0.0001)

dynRRBoost = i_dynamicRR ? math.max(math.min(1.0 + (atrRatio - 1.0) * i_dynRRMult, 1.5), 1.0) : 1.0

tp1Mode = tp1Base * dynRRBoost
tp2Mode = tp2Base * dynRRBoost
tp3Mode = tp3Base * dynRRBoost

// ‚ĒÄ‚ĒÄ‚ĒÄ Input Validation (run once at bar 0) ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
if barstate.isfirst
    if i_tp1RR >= i_tp2RR
        runtime.error("TP1 RR must be less than TP2 RR")
    if i_tp2RR >= i_tp3RR
        runtime.error("TP2 RR must be less than TP3 RR")
    if i_slATRMult <= 0
        runtime.error("SL ATR Multiplier must be > 0")
    if i_slFixedPct <= 0 or i_slFixedPct > 100
        runtime.error("SL Fixed % must be between 0 and 100")
    if i_accountSize <= 0
        runtime.error("Account Size must be greater than 0")
    if i_riskPercent <= 0 or i_riskPercent > 100
        runtime.error("Account Risk Per Trade must be between 0 and 100")
    if i_fvgMinSize <= 0 or i_fvgMinSize > 5.0
        runtime.error("FVG Minimum Size must be between 0 and 5% (valid range for FVG detection)")
    if i_trailATRMult <= 0
        runtime.error("Trailing ATR Multiplier must be > 0")
    // FIX v6.5.3-r3: Validate leverage setting for Spot trading
    if i_marketType == "Spot" and i_leverage > 1
        runtime.error("‚ö†ÔłŹ LEVERAGE WARNING: Spot trading does not support leverage > 1.\n" +
                     "Current setting: Leverage = " + str.tostring(i_leverage) + "√ó\n" +
                     "This will cause position sizing to request more capital than available.\n" +
                     "Solutions:\n" +
                     "  1. Set 'Max Leverage' = 1 for Spot trading, OR\n" +
                     "  2. Change 'Market Type' to 'Futures' if you have leverage available.\n" +
                     "Strategy will NOT execute until this is fixed.")

// ‚ĒÄ‚ĒÄ‚ĒÄ Risk Profile ‚Üí Minimum Confluence Threshold ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
minConflBase = i_riskMode == "Conservative" ? i_minConfluence + 2 :
               i_riskMode == "Aggressive"   ? math.max(i_minConfluence - 1, 1) :
               i_minConfluence
minConfl = i_autoAdjustAgg ? getAutoMinConfl(minConflBase) : minConflBase

// ============================================================================
// 1. EMA RIBBON
// ============================================================================
ema8   = ta.ema(close, getAutoEMA8())
ema21  = ta.ema(close, getAutoEMA21())
ema50  = ta.ema(close, getAutoEMA50())
ema200 = ta.ema(close, getAutoEMA200())

emaLongBias  = ema8 > ema21 and ema21 > ema50 and close > ema200
emaShortBias = ema8 < ema21 and ema21 < ema50 and close < ema200

plot(i_showEmaRibbon ? ema8   : na, "EMA 8",   color = color.new(color.lime,   30), linewidth = 1)
plot(i_showEmaRibbon ? ema21  : na, "EMA 21",  color = color.new(color.yellow, 30), linewidth = 2)
plot(i_showEmaRibbon ? ema50  : na, "EMA 50",  color = color.new(color.orange, 30), linewidth = 3)
plot(i_showEmaRibbon ? ema200 : na, "EMA 200", color = color.new(color.red,    20), linewidth = 4)

// ============================================================================
// 2. SUPERTREND
// ============================================================================
[stVal, stDir] = ta.supertrend(i_stFactor, i_stPeriod)
stBull = stDir < 0
stBear = stDir > 0

stPlot = i_showST ? stVal : na
plot(stBull ? stPlot : na, "ST Bull", color = color.new(color.teal, 20), style = plot.style_linebr, linewidth = 2)
plot(stBear ? stPlot : na, "ST Bear", color = color.new(color.red,  20), style = plot.style_linebr, linewidth = 2)

// ============================================================================
// 3. ICHIMOKU (Full 5-Component)
// ============================================================================
// Tenkan-sen  : 9-period midpoint  ‚Üí fast momentum
// Kijun-sen   : 26-period midpoint ‚Üí dynamic S/R
// Senkou A    : (Tenkan + Kijun) / 2, offset +26 ‚Üí cloud boundary (fast)
// Senkou B    : 52-period midpoint, offset +26    ‚Üí cloud boundary (slow)
// Chikou Span : current close plotted 26 bars back ‚Üí lagging confirmation

ichiHL(len) => (ta.highest(high, len) + ta.lowest(low, len)) / 2.0

tenkan  = ichiHL(i_ichiTenkan)
kijun   = ichiHL(i_ichiKijun)
senkouA = (tenkan + kijun) / 2.0
senkouB = ichiHL(i_ichiSenkou)

senkouAplot = plot(i_showIchimoku ? senkouA : na, "Senkou A",
     offset = i_ichiKijun, color = color.new(color.green, 85))
senkouBplot = plot(i_showIchimoku ? senkouB : na, "Senkou B",
     offset = i_ichiKijun, color = color.new(color.red,   85))
fill(senkouAplot, senkouBplot,
     color = senkouA >= senkouB ? color.new(color.teal, 88) : color.new(color.red, 88),
     title = "Kumo Cloud")

plot(i_showIchimoku ? tenkan : na, "Tenkan-sen",  color = color.new(color.blue,   30), linewidth = 1)
plot(i_showIchimoku ? kijun  : na, "Kijun-sen",   color = color.new(color.purple, 30), linewidth = 2)
plot(i_showIchimoku and i_showChikou ? close : na, "Chikou Span",
     color = color.new(color.aqua, 40), offset = -i_ichiKijun, linewidth = 1)

// Cloud state (FIX v6.5.3-r3: removed future offset [i_ichiKijun] - check current bar cloud, not 26 bars ahead)
ichiAboveCloud = close > math.max(senkouA, senkouB)
ichiBelowCloud = close < math.min(senkouA, senkouB)
ichiTKCross    = ta.crossover(tenkan,  kijun)   // Bullish TK cross
ichiTKDeath    = ta.crossunder(tenkan, kijun)   // Bearish TK cross
chikouBull     = close > close[i_ichiKijun]
chikouBear     = close < close[i_ichiKijun]
aboveKijun     = close > kijun
belowKijun     = close < kijun

// ============================================================================
// 4. ADX + DIRECTIONAL INDEX
// ============================================================================
[diPlus, diMinus, adxVal] = ta.dmi(i_adxPeriod, i_adxPeriod)
adxStrong = adxVal >= i_adxThresh
adxBull   = diPlus  > diMinus and adxStrong
adxBear   = diMinus > diPlus  and adxStrong

// ============================================================================
// 5. RSI
// ============================================================================
rsiVal      = ta.rsi(close, i_rsiPeriod)
rsiOB       = rsiVal >= i_rsiOB
rsiOS       = rsiVal <= i_rsiOS
rsiBullZone = rsiVal > 50 and rsiVal < i_rsiOB
rsiBearZone = rsiVal < 50 and rsiVal > i_rsiOS

// ============================================================================
// 6. MACD
// ============================================================================
[macdLine, macdSignal, macdHist] = ta.macd(close, i_macdFast, i_macdSlow, i_macdSig)
macdBull      = macdLine > macdSignal and macdLine > 0
macdBear      = macdLine < macdSignal and macdLine < 0
macdCrossUp   = ta.crossover(macdLine,  macdSignal)
macdCrossDown = ta.crossunder(macdLine, macdSignal)
macdMomentum  = macdHist > macdHist[1]

// ============================================================================
// 7. STOCHASTIC
// ============================================================================
stochRaw       = ta.stoch(close, high, low, i_stochK)
stochK         = ta.sma(stochRaw, i_stochSmooth)
stochD         = ta.sma(stochK, i_stochD)
stochCrossUp   = ta.crossover(stochK,  stochD)
stochCrossDown = ta.crossunder(stochK, stochD)
stochBull      = stochK < i_stochOS and stochCrossUp and close > ema200
stochBear      = stochK > i_stochOB and stochCrossDown and close < ema200
stochMid       = stochK > 50

// ============================================================================
// 8. CCI
// ============================================================================
cciVal      = ta.cci(close, i_cciPeriod)
cciBull     = cciVal >  100
cciBear     = cciVal < -100
cciZero     = ta.crossover(cciVal,  0)
cciZeroBear = ta.crossunder(cciVal, 0)

// ============================================================================
// 9. ATR (alias declared above ‚ÄĒ reused throughout)
// ============================================================================
// atrVal = atrValRaw  ‚Üź already assigned

// ============================================================================
// 10. BOLLINGER BANDS
// ============================================================================
[bbMid, bbUp, bbLo] = ta.bb(close, i_bbPeriod, i_bbStdDev)
bbWidth   = bbUp - bbLo
bbWidthMA = ta.sma(bbWidth, 50)
bbSqueeze = bbWidth < bbWidthMA * i_bbSqueezeRatio
bbExpand  = bbWidth > bbWidthMA * i_bbExpandRatio
bbBull    = close > bbMid and not bbSqueeze
bbBear    = close < bbMid and not bbSqueeze

plot(i_showBB ? bbUp  : na, "BB Upper", color = color.new(color.gray, 60))
plot(i_showBB ? bbMid : na, "BB Mid",   color = color.new(color.gray, 60), style = plot.style_circles)
plot(i_showBB ? bbLo  : na, "BB Lower", color = color.new(color.gray, 60))

// ============================================================================
// 11. KELTNER CHANNEL
// ============================================================================
kcMid  = ta.ema(close, i_kcPeriod)
kcUp   = kcMid + i_kcMult * atrVal
kcLo   = kcMid - i_kcMult * atrVal
kcBull = close > kcUp
kcBear = close < kcLo

plot(i_showKC ? kcUp  : na, "KC Upper", color = color.new(color.purple, 70))
plot(i_showKC ? kcMid : na, "KC Mid",   color = color.new(color.purple, 70))
plot(i_showKC ? kcLo  : na, "KC Lower", color = color.new(color.purple, 70))

// ============================================================================
// 11b. HYPER-SPECTRAL NEURAL FLOW (HSNF)
// ============================================================================
// Double-EMA (DEMA-style) smoothing for reduced lag.
// Fast / Med / Slow / Ultra lines form a layered "neural flow" trend filter.
gaussSmooth(src, len) =>
    ta.ema(ta.ema(src, len), len)

hsnfFast  = gaussSmooth(close, i_hsnfFast)
hsnfMed   = gaussSmooth(close, i_hsnfMed)
hsnfSlow  = gaussSmooth(close, i_hsnfSlow)
hsnfUltra = gaussSmooth(close, i_hsnfUltra)

hsnfBull     = hsnfFast > hsnfMed and hsnfMed > hsnfSlow and close > hsnfSlow
hsnfBullWeak = hsnfFast > hsnfMed and close > hsnfMed    and not hsnfBull
hsnfBear     = hsnfFast < hsnfMed and hsnfMed < hsnfSlow and close < hsnfSlow
hsnfBearWeak = hsnfFast < hsnfMed and close < hsnfMed    and not hsnfBear

hsnfFastPlot  = plot(i_showHSNF ? hsnfFast  : na, "HSNF Fast",  color = color.new(color.fuchsia, 40), linewidth = 2)
hsnfMedPlot   = plot(i_showHSNF ? hsnfMed   : na, "HSNF Med",   color = color.new(color.blue,    40), linewidth = 2)
hsnfSlowPlot  = plot(i_showHSNF ? hsnfSlow  : na, "HSNF Slow",  color = color.new(color.purple,  40), linewidth = 2)
hsnfUltraPlot = plot(i_showHSNF ? hsnfUltra : na, "HSNF Ultra", color = color.new(color.red,     30), linewidth = 1)

hsnfFillColor = (i_showHSNF and i_hsnfCloud) ?
     (hsnfBull ? color.new(color.green, 88) : color.new(color.red, 88)) : na
fill(hsnfFastPlot, hsnfSlowPlot, color = hsnfFillColor, title = "HSNF Cloud")

// ============================================================================
// 11c. AUTO SUPPORT & RESISTANCE
// ============================================================================
srHigh = ta.pivothigh(high, i_srLookback, i_srLookback)
srLow  = ta.pivotlow (low,  i_srLookback, i_srLookback)

var float srTopLevel = na
var float srBotLevel = na

if not na(srHigh)
    srTopLevel := srHigh
if not na(srLow)
    srBotLevel := srLow

srZonePct     = i_srZone / 100.0
srNearResist  = not na(srTopLevel) and math.abs(close - srTopLevel) / math.max(srTopLevel, 0.000001) < srZonePct
srNearSupport = not na(srBotLevel) and math.abs(close - srBotLevel) / math.max(srBotLevel, 0.000001) < srZonePct

var line srHighLine = na
var line srLowLine  = na

if i_showSR
    if not na(srTopLevel)
        if not na(srHighLine) and math.abs(line.get_y1(srHighLine) - srTopLevel) > atrVal * 2
            line.delete(srHighLine)
            srHighLine := na
        if na(srHighLine)
            srHighLine := line.new(bar_index - i_srLookback * 2, srTopLevel, bar_index, srTopLevel,
                 color = color.new(color.red, 60), style = line.style_solid)
        else
            line.set_xy1(srHighLine, bar_index - i_srLookback * 2, srTopLevel)
            line.set_xy2(srHighLine, bar_index, srTopLevel)

    if not na(srBotLevel)
        if not na(srLowLine) and math.abs(line.get_y1(srLowLine) - srBotLevel) > atrVal * 2
            line.delete(srLowLine)
            srLowLine := na
        if na(srLowLine)
            srLowLine := line.new(bar_index - i_srLookback * 2, srBotLevel, bar_index, srBotLevel,
                 color = color.new(color.green, 60), style = line.style_solid)
        else
            line.set_xy1(srLowLine, bar_index - i_srLookback * 2, srBotLevel)
            line.set_xy2(srLowLine, bar_index, srBotLevel)

if i_showSRLabels and srNearSupport and barstate.isconfirmed
    label.new(bar_index, low, "SR SUPPORT",
         color = color.new(color.green, 20), textcolor = color.white,
         style = label.style_label_up, size = adaptiveSizeVal)

if i_showSRLabels and srNearResist and barstate.isconfirmed
    label.new(bar_index, high, "SR RESIST",
         color = color.new(color.red, 20), textcolor = color.white,
         style = label.style_label_down, size = adaptiveSizeVal)

// ============================================================================
// 11d. TC 1D VOLUME SIGNALS
// ============================================================================
// Detects price-volume confirmation:
//   Bull: price rebounds from dip + volume spike + close above VWAP
//   Bear: price drops from peak  + volume spike + close below VWAP
vwapVal   = ta.vwap(close)
tc1dVolMA = ta.sma(volume, 20)

tc1dBull = close > vwapVal and volume > tc1dVolMA * i_tc1dVolMult and
     close > close[1] and close[1] < close[2]

tc1dBear = close < vwapVal and volume > tc1dVolMA * i_tc1dVolMult and
     close < close[1] and close[1] > close[2]

if i_showTC1D and tc1dBull and barstate.isconfirmed
    label.new(bar_index, low, "TC 1D BUY",
         color = color.new(color.lime, 20), textcolor = color.black,
         style = label.style_label_up, size = adaptiveSizeVal)

if i_showTC1D and tc1dBear and barstate.isconfirmed
    label.new(bar_index, high, "TC 1D SELL",
         color = color.new(color.orange, 20), textcolor = color.black,
         style = label.style_label_down, size = adaptiveSizeVal)

// ============================================================================
// 11e. OSCILLATOR MATRIX
// ============================================================================
// Three sub-oscillators vote; ‚Č•2/3 triggers a Bull or Bear signal.
//   Hyper Wave  : fast CCI variant
//   Smart Money : Chaikin Money Flow proxy
//   Reversal    : RSI momentum inflection

// Hyper Wave
hwVal  = ta.cci(close, i_oscHWLen)
hwBull = hwVal > 0 and hwVal > hwVal[1]
hwBear = hwVal < 0 and hwVal < hwVal[1]

// Smart Money Flow (CMF proxy)
smfHigh  = ta.highest(high, i_oscSMFLen)
smfLow   = ta.lowest (low,  i_oscSMFLen)
smfRange = math.max(smfHigh - smfLow, 0.0001)
smfMFV   = ((close - smfLow) - (smfHigh - close)) / smfRange * volume
smfCMF   = ta.sma(smfMFV, i_oscSMFLen) / math.max(ta.sma(volume, i_oscSMFLen), 0.0001)
smfBull  = smfCMF >  0.05
smfBear  = smfCMF < -0.05

// Reversal: RSI momentum shift
oscRevBull = rsiVal < 40 and rsiVal > rsiVal[1] and rsiVal[1] < rsiVal[2]
oscRevBear = rsiVal > 60 and rsiVal < rsiVal[1] and rsiVal[1] > rsiVal[2]

// Vote tally
oscBullCount = (hwBull ? 1 : 0) + (smfBull ? 1 : 0) + (oscRevBull ? 1 : 0)
oscBearCount = (hwBear ? 1 : 0) + (smfBear ? 1 : 0) + (oscRevBear ? 1 : 0)
oscBull = oscBullCount >= 2
oscBear = oscBearCount >= 2

// ============================================================================
// 12. VOLUME ANALYSIS
// ============================================================================
volMA    = ta.sma(volume, i_volMAPeriod)
volSpike = volume > volMA * i_volSpikeMult
volBull  = close > open and volume > volMA
volBear  = close < open and volume > volMA

obvVal  = ta.obv
obvEma  = ta.ema(obvVal, 21)
obvBull = not na(obvVal) and not na(obvEma) and obvVal > obvEma
obvBear = not na(obvVal) and not na(obvEma) and obvVal < obvEma

// ============================================================================
// 13. SWING HIGH / LOW DETECTION
// ============================================================================
swingLen = math.max(getAutoSwingLen(i_swingLen), 3)

swingHigh = ta.pivothigh(high, swingLen, swingLen)
swingLow  = ta.pivotlow (low,  swingLen, swingLen)

var float lastSwingHigh    = na
var float lastSwingLow     = na
var float prevSwingHigh    = na
var float prevSwingLow     = na
var int   lastSwingHighBar = na
var int   lastSwingLowBar  = na

if not na(swingHigh)
    prevSwingHigh    := lastSwingHigh
    lastSwingHigh    := swingHigh
    lastSwingHighBar := bar_index - swingLen

if not na(swingLow)
    prevSwingLow    := lastSwingLow
    lastSwingLow    := swingLow
    lastSwingLowBar := bar_index - swingLen

hhDetected = not na(lastSwingHigh) and not na(prevSwingHigh) and lastSwingHigh > prevSwingHigh
llDetected = not na(lastSwingLow)  and not na(prevSwingLow)  and lastSwingLow  < prevSwingLow
hlDetected = not na(lastSwingLow)  and not na(prevSwingLow)  and lastSwingLow  > prevSwingLow
lhDetected = not na(lastSwingHigh) and not na(prevSwingHigh) and lastSwingHigh < prevSwingHigh

// ============================================================================
// 14. MARKET STRUCTURE: BOS & CHoCH
// ============================================================================
var bool msBullish = false
var bool msBearish = false
var bool bosUp     = false
var bool bosDown   = false
var bool chochUp   = false
var bool chochDown = false

bosUpRaw   = not na(lastSwingHigh) and not na(prevSwingHigh) and
     close > lastSwingHigh and close[1] <= lastSwingHigh
bosDownRaw = not na(lastSwingLow)  and not na(prevSwingLow)  and
     close < lastSwingLow  and close[1] >= lastSwingLow

bosUp   := bosUpRaw
bosDown := bosDownRaw

chochUp   := msBearish and hhDetected
chochDown := msBullish and llDetected

if bosUp or chochUp
    msBullish := true
    msBearish := false

if bosDown or chochDown
    msBearish := true
    msBullish := false

if i_showMarketStr and bosUp and barstate.isconfirmed
    label.new(bar_index, high, "BOS‚ÜĎ",
         color = color.new(color.green, 20), textcolor = color.white,
         style = label.style_label_down, size = adaptiveSizeVal)

if i_showMarketStr and bosDown and barstate.isconfirmed
    label.new(bar_index, low, "BOS‚Üď",
         color = color.new(color.red, 20), textcolor = color.white,
         style = label.style_label_up, size = adaptiveSizeVal)

if i_showMarketStr and chochUp and barstate.isconfirmed
    label.new(bar_index, high, "CHoCH‚ÜĎ",
         color = color.new(color.teal, 10), textcolor = color.white,
         style = label.style_label_down, size = adaptiveSizeVal)

if i_showMarketStr and chochDown and barstate.isconfirmed
    label.new(bar_index, low, "CHoCH‚Üď",
         color = color.new(color.orange, 10), textcolor = color.white,
         style = label.style_label_up, size = adaptiveSizeVal)

// ============================================================================
// 15. ORDER BLOCKS
// ============================================================================
var box obBoxBull = na
var box obBoxBear = na

if i_showOrderBlocks and bosUp
    if not na(obBoxBull)
        box.delete(obBoxBull)
    obBoxBull := box.new(bar_index - swingLen, open[1], bar_index, close[1],
         border_color = color.new(color.teal, 30),
         bgcolor      = color.new(color.teal, 88))

if i_showOrderBlocks and bosDown
    if not na(obBoxBear)
        box.delete(obBoxBear)
    obBoxBear := box.new(bar_index - swingLen, open[1], bar_index, close[1],
         border_color = color.new(color.red, 30),
         bgcolor      = color.new(color.red, 88))

// ============================================================================
// 16. FIBONACCI AUTO LEVELS
// ============================================================================
var line fibLine236 = na
var line fibLine382 = na
var line fibLine500 = na
var line fibLine618 = na
var line fibLine786 = na

fibLen   = modeDay ? 30 : modePosition ? 100 : 60
fibHigh  = ta.highest(high, fibLen)
fibLow   = ta.lowest (low,  fibLen)
fibRange = fibHigh - fibLow

fib236 = fibLow + fibRange * 0.236
fib382 = fibLow + fibRange * 0.382
fib500 = fibLow + fibRange * 0.500
fib618 = fibLow + fibRange * 0.618
fib786 = fibLow + fibRange * 0.786

if i_showFib and (barstate.islast or barstate.isrealtime)
    if not na(fibLine236)
        line.delete(fibLine236)
        line.delete(fibLine382)
        line.delete(fibLine500)
        line.delete(fibLine618)
        line.delete(fibLine786)
    fibLine236 := line.new(bar_index - fibLen, fib236, bar_index, fib236, color = color.new(color.yellow, 40), style = line.style_dashed)
    fibLine382 := line.new(bar_index - fibLen, fib382, bar_index, fib382, color = color.new(color.orange, 40), style = line.style_dashed)
    fibLine500 := line.new(bar_index - fibLen, fib500, bar_index, fib500, color = color.new(color.aqua,   40), style = line.style_dashed)
    fibLine618 := line.new(bar_index - fibLen, fib618, bar_index, fib618, color = color.new(color.red,    40), style = line.style_dashed)
    fibLine786 := line.new(bar_index - fibLen, fib786, bar_index, fib786, color = color.new(color.purple, 40), style = line.style_dashed)

// ============================================================================
// 17. PARABOLIC SAR
// ============================================================================
psarVal  = ta.sar(i_psarStart, i_psarInc, i_psarMax)
psarBull = close > psarVal
psarBear = close < psarVal

// ============================================================================
// 18. MULTI-TIMEFRAME ANALYSIS (MTF)
// ============================================================================
// Three higher timeframes (auto-selected or manual) each vote bull/bear.
// HTF1 also includes SuperTrend confirmation for stronger filtering.
// ‚Č•2/3 frames aligned triggers mtfBullAlign / mtfBearAlign.
// All 3 frames aligned triggers mtfFullBull / mtfFullBear.

htf1_ema21 = request.security(syminfo.tickerid, htf1Actual, ta.ema(close, 21),  lookahead = barmerge.lookahead_off)
htf1_ema50 = request.security(syminfo.tickerid, htf1Actual, ta.ema(close, 50),  lookahead = barmerge.lookahead_off)
htf1_rsi   = request.security(syminfo.tickerid, htf1Actual, ta.rsi(close, 14),  lookahead = barmerge.lookahead_off)
htf1_close = request.security(syminfo.tickerid, htf1Actual, close,               lookahead = barmerge.lookahead_off)

[_htf1_stVal, _htf1_stDir] = request.security(
     syminfo.tickerid, htf1Actual,
     ta.supertrend(i_stFactor, i_stPeriod),
     lookahead = barmerge.lookahead_off)

htf1TrendBull = not na(_htf1_stDir) and _htf1_stDir < 0
htf1TrendBear = not na(_htf1_stDir) and _htf1_stDir > 0

htf1Bull = not na(htf1_close) and not na(htf1_ema21) and not na(htf1_ema50) and not na(htf1_rsi) and htf1_close > htf1_ema21 and htf1_ema21 > htf1_ema50 and htf1_rsi > 50 and htf1TrendBull
htf1Bear = not na(htf1_close) and not na(htf1_ema21) and not na(htf1_ema50) and not na(htf1_rsi) and htf1_close < htf1_ema21 and htf1_ema21 < htf1_ema50 and htf1_rsi < 50 and htf1TrendBear

htf2_ema21 = request.security(syminfo.tickerid, htf2Actual, ta.ema(close, 21), lookahead = barmerge.lookahead_off)
htf2_ema50 = request.security(syminfo.tickerid, htf2Actual, ta.ema(close, 50), lookahead = barmerge.lookahead_off)
htf2_rsi   = request.security(syminfo.tickerid, htf2Actual, ta.rsi(close, 14), lookahead = barmerge.lookahead_off)
htf2_close = request.security(syminfo.tickerid, htf2Actual, close,              lookahead = barmerge.lookahead_off)

htf2Bull = not na(htf2_close) and not na(htf2_ema21) and not na(htf2_ema50) and not na(htf2_rsi) and htf2_close > htf2_ema21 and htf2_ema21 > htf2_ema50 and htf2_rsi > 50
htf2Bear = not na(htf2_close) and not na(htf2_ema21) and not na(htf2_ema50) and not na(htf2_rsi) and htf2_close < htf2_ema21 and htf2_ema21 < htf2_ema50 and htf2_rsi < 50

htf3_ema21  = request.security(syminfo.tickerid, htf3Actual, ta.ema(close, 21),  lookahead = barmerge.lookahead_off)
htf3_ema200 = request.security(syminfo.tickerid, htf3Actual, ta.ema(close, 200), lookahead = barmerge.lookahead_off)
htf3_rsi    = request.security(syminfo.tickerid, htf3Actual, ta.rsi(close, 14),  lookahead = barmerge.lookahead_off)
htf3_close  = request.security(syminfo.tickerid, htf3Actual, close,               lookahead = barmerge.lookahead_off)

htf3Bull = not na(htf3_close) and not na(htf3_ema21) and not na(htf3_ema200) and not na(htf3_rsi) and htf3_close > htf3_ema21 and htf3_close > htf3_ema200 and htf3_rsi > 50
htf3Bear = not na(htf3_close) and not na(htf3_ema21) and not na(htf3_ema200) and not na(htf3_rsi) and htf3_close < htf3_ema21 and htf3_close < htf3_ema200 and htf3_rsi < 50

mtfBullCount = (htf1Bull ? 1 : 0) + (htf2Bull ? 1 : 0) + (htf3Bull ? 1 : 0)
mtfBearCount = (htf1Bear ? 1 : 0) + (htf2Bear ? 1 : 0) + (htf3Bear ? 1 : 0)

mtfBullAlign = mtfBullCount >= 2
mtfBearAlign = mtfBearCount >= 2
mtfFullBull  = mtfBullCount == 3
mtfFullBear  = mtfBearCount == 3

// ‚ĒÄ‚ĒÄ‚ĒÄ [v6] Market Dominance Proxy ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
// HTF3 (Daily) + HTF2 (4H) both aligned = dominant regime.
// Divergence = HTF1 contradicts the higher regime ‚Üí caution.
htfDominanceBull = htf3Bull and htf2Bull
htfDominanceBear = htf3Bear and htf2Bear
htfDivergence    = (htf3Bull and htf2Bull and htf1Bear) or (htf3Bear and htf2Bear and htf1Bull)

// ============================================================================
// 19. SESSION FILTER
// ============================================================================
// Converts HHMM integer to minutes-of-day, then checks if current bar is inside
// the user-defined trading window. Supports wrap-around (e.g. 2200‚Äď0600 UTC).

sessionToMinutes(hhmm) =>
    hh = math.floor(hhmm / 100)
    mm = hhmm - hh * 100
    hh * 60 + mm

inSessionRangeMinutes(minStart, minEnd) =>
    curMin = hour * 60 + minute
    minStart == minEnd ? true :
     minStart < minEnd ? (curMin >= minStart and curMin < minEnd) :
     (curMin >= minStart or curMin < minEnd)

sessionOK = not i_filterSession or
     inSessionRangeMinutes(sessionToMinutes(i_sessionStart), sessionToMinutes(i_sessionEnd))

// ‚ĒÄ‚ĒÄ‚ĒÄ [v6] Session Bias Detection (UTC-based) ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
inSessionRange(startHour, endHour) =>
    startHour == endHour ? true :
     startHour < endHour ? (hour >= startHour and hour < endHour) :
     (hour >= startHour or hour < endHour)

inAsia    = inSessionRange(i_asiaOpen,   i_asiaClose)
inLondon  = inSessionRange(i_londonOpen, i_londonClose)
inNewYork = inSessionRange(i_nyOpen,     i_nyClose)

asiaColor   = color.new(color.blue,   93)
londonColor = color.new(color.orange, 93)
nyColor     = color.new(color.purple, 93)

bgcolor(i_showSession and inAsia    and not inLondon  ? asiaColor   : na, title = "Asia Session")
bgcolor(i_showSession and inLondon  and not inNewYork ? londonColor : na, title = "London Session")
bgcolor(i_showSession and inNewYork                   ? nyColor     : na, title = "New York Session")

sessionName  = inNewYork and inLondon ? "NY+LON"   : inNewYork ? "New York" : inLondon ? "London" : inAsia ? "Asia" : "Off-Hours"
sessionEmoji = inNewYork ? "ūüóĹ" : inLondon ? "ūüŹõÔłŹ" : inAsia ? "ūüŹģ" : "ūüĆô"

// ============================================================================
// 20. FAIR VALUE GAP (FVG) DETECTION
// ============================================================================
// A 3-candle displacement leaves an imbalance (gap) between candle[2] and
// candle[0].  These zones act as price magnets ("mitigation").
//   Bullish FVG : high[2] < low[0]  ‚ÄĒ bullish imbalance
//   Bearish FVG : low[2]  > high[0] ‚ÄĒ bearish imbalance
// Boxes fade to near-transparent once mitigated (price re-enters the zone).
// FVG scores (max 2 pts each) feed the Confluence Engine (Grub 3).

fvgMinBull = i_fvgMinSize / 100.0 * math.max(0.000001, math.abs(high[2]))
fvgMinBear = i_fvgMinSize / 100.0 * math.max(0.000001, math.abs(low[2]))

fvgBullDetect = high[2] < low[0]  and (low[0]  - high[2]) >= fvgMinBull
fvgBearDetect = low[2]  > high[0] and (low[2]  - high[0]) >= fvgMinBear

var box[]  fvgBullBoxes  = array.new_box()
var box[]  fvgBearBoxes  = array.new_box()
var bool[] fvgBullMitig  = array.new_bool()
var bool[] fvgBearMitig  = array.new_bool()

// Per-bar FVG score accumulators (non-var: reset each bar)
int fvgBullScore = 0
int fvgBearScore = 0

// ‚ĒÄ‚ĒÄ New bullish FVG ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
if fvgBullDetect
    b = box.new(bar_index - 2, low[0], bar_index + 20, high[2],
         border_color = i_showFVG ? color.new(color.lime, 40) : color.new(color.lime, 100),
         bgcolor      = i_showFVG ? color.new(color.lime, 85) : color.new(color.lime, 100),
         border_width = 1)
    array.push(fvgBullBoxes, b)
    array.push(fvgBullMitig, false)
    if i_showFVG and barstate.isconfirmed
        label.new(bar_index - 1, low[0], "FVG‚ÜĎ",
             color = color.new(color.lime, 30), textcolor = color.white,
             style = label.style_label_up, size = size.tiny)

// ‚ĒÄ‚ĒÄ New bearish FVG ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
if fvgBearDetect
    b = box.new(bar_index - 2, low[2], bar_index + 20, high[0],
         border_color = i_showFVG ? color.new(color.red, 40) : color.new(color.red, 100),
         bgcolor      = i_showFVG ? color.new(color.red, 85) : color.new(color.red, 100),
         border_width = 1)
    array.push(fvgBearBoxes, b)
    array.push(fvgBearMitig, false)
    if i_showFVG and barstate.isconfirmed
        label.new(bar_index - 1, high[0], "FVG‚Üď",
             color = color.new(color.red, 30), textcolor = color.white,
             style = label.style_label_down, size = size.tiny)

// ‚ĒÄ‚ĒÄ Prune oldest boxes beyond the cap ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
if array.size(fvgBullBoxes) > i_maxFVGBoxes
    oldest = array.shift(fvgBullBoxes)
    if not na(oldest)
        box.delete(oldest)
    array.shift(fvgBullMitig)

if array.size(fvgBearBoxes) > i_maxFVGBoxes
    oldest = array.shift(fvgBearBoxes)
    if not na(oldest)
        box.delete(oldest)
    array.shift(fvgBearMitig)

// ‚ĒÄ‚ĒÄ Mitigation check + score accumulation (bull FVGs) ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
// Performance optimization: limit active scoring to recent boxes (max 2 pts cap)
int fvgBullSize = array.size(fvgBullBoxes)
if fvgBullSize > 0
    int scoreCount = 0  // Early-exit counter
    for i = fvgBullSize - 1 to 0
        b     = array.get(fvgBullBoxes, i)
        mitig = array.get(fvgBullMitig, i)
        if not mitig
            if barstate.islast or barstate.isrealtime
                box.set_right(b, bar_index + 10)
            bTop = box.get_top(b)
            bBot = box.get_bottom(b)
            bullProx = close <= bTop + atrVal * 2
            if low <= bTop and high >= bBot
                array.set(fvgBullMitig, i, true)
                box.set_bgcolor(b,       color.new(color.lime, 96))
                box.set_border_color(b,  color.new(color.lime, 80))
            else if bullProx and scoreCount < 2
                fvgBullScore += 1
                scoreCount += 1  // Track scoring to enable early exit at cap

// ‚ĒÄ‚ĒÄ Mitigation check + score accumulation (bear FVGs) ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
// Performance optimization: limit active scoring to recent boxes (max 2 pts cap)
int fvgBearSize = array.size(fvgBearBoxes)
if fvgBearSize > 0
    int scoreCount = 0  // Early-exit counter
    for i = fvgBearSize - 1 to 0
        b     = array.get(fvgBearBoxes, i)
        mitig = array.get(fvgBearMitig, i)
        if not mitig
            if barstate.islast or barstate.isrealtime
                box.set_right(b, bar_index + 10)
            bTop = box.get_top(b)
            bBot = box.get_bottom(b)
            bearProx = close >= bBot - atrVal * 2
            if low <= bTop and high >= bBot
                array.set(fvgBearMitig, i, true)
                box.set_bgcolor(b,       color.new(color.red, 96))
                box.set_border_color(b,  color.new(color.red, 80))
            else if bearProx and scoreCount < 2
                fvgBearScore += 1
                scoreCount += 1  // Track scoring to enable early exit at cap

// Cap FVG contribution to max 2 points each
fvgBullScoreCapped = math.min(fvgBullScore, 2)
fvgBearScoreCapped = math.min(fvgBearScore, 2)

// ============================================================================
// 21. LIQUIDITY SWEEP (STOP HUNT) DETECTION
// ============================================================================
// A Liquidity Sweep occurs when price briefly penetrates a swing high/low
// (clearing resting stops) and then sharply reverses back inside the range.
//   Bull Sweep : spike BELOW lastSwingLow  ‚Üí closes ABOVE it ‚Üí reversal up
//   Bear Sweep : spike ABOVE lastSwingHigh ‚Üí closes BELOW it ‚Üí reversal down
// Confirmation (liqSweepBullConf / liqSweepBearConf) requires a volume spike
// on the same bar, indicating institutional absorption.

liqSweepThresh = i_liqSweepFactor * atrVal

var bool liqSweepBull = false
var bool liqSweepBear = false

liqSweepBull := not na(lastSwingLow) and
     low  < lastSwingLow  - liqSweepThresh and
     close > lastSwingLow and
     (high - low) > atrVal * 1.5 and
     not liqSweepBull[1]

liqSweepBear := not na(lastSwingHigh) and
     high  > lastSwingHigh + liqSweepThresh and
     close < lastSwingHigh and
     (high - low) > atrVal * 1.5 and
     not liqSweepBear[1]

liqSweepBullConf = liqSweepBull and volSpike
liqSweepBearConf = liqSweepBear and volSpike

if i_showLiqSweep and liqSweepBull and barstate.isconfirmed
    label.new(bar_index, low, "ūüíß LIQ‚ÜĎ\nSweep",
         color = color.new(color.aqua, 20), textcolor = color.black,
         style = label.style_label_up, size = adaptiveSizeVal)

if i_showLiqSweep and liqSweepBear and barstate.isconfirmed
    label.new(bar_index, high, "ūüíß LIQ‚Üď\nSweep",
         color = color.new(color.orange, 20), textcolor = color.black,
         style = label.style_label_down, size = adaptiveSizeVal)

// ============================================================================
// 22. ADVANCED DIVERGENCE ENGINE
// ============================================================================
// Detects Regular (reversal) and Hidden (continuation) divergence on three
// oscillators: RSI, MACD, and Stochastic.
//
//   Regular Bullish  : price Lower Low,   osc Higher Low  ‚Üí reversal up
//   Regular Bearish  : price Higher High, osc Lower High  ‚Üí reversal down
//   Hidden  Bullish  : price Higher Low,  osc Lower Low   ‚Üí continuation up
//   Hidden  Bearish  : price Lower High,  osc Higher High ‚Üí continuation down
//
// ‚Č•1 oscillator confirming = valid signal.
// 2+ = strong (High Quality).
// Score: Regular Div = 2 pts, Hidden Div = 1 pt (per direction).

divLB = i_divLookback

// Pivot helpers
pricePH = ta.pivothigh(high,    divLB, divLB)
pricePL = ta.pivotlow (low,     divLB, divLB)
rsiPH   = ta.pivothigh(rsiVal,  divLB, divLB)
rsiPL   = ta.pivotlow (rsiVal,  divLB, divLB)
macdPH  = ta.pivothigh(macdLine, divLB, divLB)
macdPL  = ta.pivotlow (macdLine, divLB, divLB)
stochPH = ta.pivothigh(stochK,  divLB, divLB)
stochPL = ta.pivotlow (stochK,  divLB, divLB)

// Pivot history buffers
var float lastPricePH  = na
var float lastPricePL  = na
var float lastRsiPH    = na
var float lastRsiPL    = na
var float lastMacdPH   = na
var float lastMacdPL   = na
var float lastStochPH  = na
var float lastStochPL  = na
var float prev2PricePH = na
var float prev2PricePL = na
var float prev2RsiPH   = na
var float prev2RsiPL   = na
var float prev2MacdPH  = na
var float prev2MacdPL  = na
var float prev2StochPH = na
var float prev2StochPL = na

// Label cooldown guards (bar-index based)
var int lastDivBullRegBar = na
var int lastDivBearRegBar = na
var int lastDivBullHidBar = na
var int lastDivBearHidBar = na

// Update pivot buffers
if not na(pricePH)
    prev2PricePH := lastPricePH
    lastPricePH  := pricePH

if not na(pricePL)
    prev2PricePL := lastPricePL
    lastPricePL  := pricePL

if not na(rsiPH)
    prev2RsiPH := lastRsiPH
    lastRsiPH  := rsiPH

if not na(rsiPL)
    prev2RsiPL := lastRsiPL
    lastRsiPL  := rsiPL

if not na(macdPH)
    prev2MacdPH := lastMacdPH
    lastMacdPH  := macdPH

if not na(macdPL)
    prev2MacdPL := lastMacdPL
    lastMacdPL  := macdPL

if not na(stochPH)
    prev2StochPH := lastStochPH
    lastStochPH  := stochPH

if not na(stochPL)
    prev2StochPL := lastStochPL
    lastStochPL  := stochPL

// ‚ĒÄ‚ĒÄ RSI Divergence ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
rsiRegBull = not na(lastPricePL) and not na(prev2PricePL) and
     not na(lastRsiPL)  and not na(prev2RsiPL)  and
     lastPricePL < prev2PricePL and lastRsiPL  > prev2RsiPL and
     lastRsiPL < 50

rsiRegBear = not na(lastPricePH) and not na(prev2PricePH) and
     not na(lastRsiPH)  and not na(prev2RsiPH)  and
     lastPricePH > prev2PricePH and lastRsiPH  < prev2RsiPH and
     lastRsiPH > 50

rsiHidBull = not na(lastPricePL) and not na(prev2PricePL) and
     not na(lastRsiPL)  and not na(prev2RsiPL)  and
     lastPricePL > prev2PricePL and lastRsiPL  < prev2RsiPL

rsiHidBear = not na(lastPricePH) and not na(prev2PricePH) and
     not na(lastRsiPH)  and not na(prev2RsiPH)  and
     lastPricePH < prev2PricePH and lastRsiPH  > prev2RsiPH

// ‚ĒÄ‚ĒÄ MACD Divergence ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
macdRegBull = not na(lastPricePL) and not na(prev2PricePL) and
     not na(lastMacdPL) and not na(prev2MacdPL) and
     lastPricePL < prev2PricePL and lastMacdPL > prev2MacdPL

macdRegBear = not na(lastPricePH) and not na(prev2PricePH) and
     not na(lastMacdPH) and not na(prev2MacdPH) and
     lastPricePH > prev2PricePH and lastMacdPH < prev2MacdPH

macdHidBull = not na(lastPricePL) and not na(prev2PricePL) and
     not na(lastMacdPL) and not na(prev2MacdPL) and
     lastPricePL > prev2PricePL and lastMacdPL < prev2MacdPL

macdHidBear = not na(lastPricePH) and not na(prev2PricePH) and
     not na(lastMacdPH) and not na(prev2MacdPH) and
     lastPricePH < prev2PricePH and lastMacdPH > prev2MacdPH

// ‚ĒÄ‚ĒÄ Stochastic Divergence ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
stochRegBull = not na(lastPricePL) and not na(prev2PricePL) and
     not na(lastStochPL) and not na(prev2StochPL) and
     lastPricePL < prev2PricePL and lastStochPL > prev2StochPL and
     lastStochPL < 40

stochRegBear = not na(lastPricePH) and not na(prev2PricePH) and
     not na(lastStochPH) and not na(prev2StochPH) and
     lastPricePH > prev2PricePH and lastStochPH < prev2StochPH and
     lastStochPH > 60

stochHidBull = not na(lastPricePL) and not na(prev2PricePL) and
     not na(lastStochPL) and not na(prev2StochPL) and
     lastPricePL > prev2PricePL and lastStochPL < prev2StochPL

stochHidBear = not na(lastPricePH) and not na(prev2PricePH) and
     not na(lastStochPH) and not na(prev2StochPH) and
     lastPricePH < prev2PricePH and lastStochPH > prev2StochPH

// ‚ĒÄ‚ĒÄ Combined Divergence Signals ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
divBullRegCount = (rsiRegBull  ? 1 : 0) + (macdRegBull  ? 1 : 0) + (stochRegBull  ? 1 : 0)
divBearRegCount = (rsiRegBear  ? 1 : 0) + (macdRegBear  ? 1 : 0) + (stochRegBear  ? 1 : 0)
divBullHidCount = (rsiHidBull  ? 1 : 0) + (macdHidBull  ? 1 : 0) + (stochHidBull  ? 1 : 0)
divBearHidCount = (rsiHidBear  ? 1 : 0) + (macdHidBear  ? 1 : 0) + (stochHidBear  ? 1 : 0)

var bool divBullReg = false
var bool divBearReg = false
var bool divBullHid = false
var bool divBearHid = false

divBullReg := divBullRegCount >= 1 and not divBullReg[1]
divBearReg := divBearRegCount >= 1 and not divBearReg[1]
divBullHid := divBullHidCount >= 1 and not divBullHid[1]
divBearHid := divBearHidCount >= 1 and not divBearHid[1]

// Score contribution: Regular divergence (reversal) = 2 pts, Hidden (continuation) = 1 pt
divBullScore = math.min((divBullReg ? 2 : 0) + (divBullHid ? 1 : 0), 3)
divBearScore = math.min((divBearReg ? 2 : 0) + (divBearHid ? 1 : 0), 3)

// ‚ĒÄ‚ĒÄ Divergence Labels ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
if i_showDivLabels
    divLabelCooldown = divLB * 2

    if divBullReg and not na(pricePL) and barstate.isconfirmed and
         (na(lastDivBullRegBar) or bar_index - lastDivBullRegBar > divLabelCooldown)
        label.new(bar_index - divLB, low[divLB],
             "ūüďź RegDiv‚ÜĎ\n" + str.tostring(divBullRegCount) + "/3",
             color = color.new(color.lime, 20), textcolor = color.black,
             style = label.style_label_up, size = adaptiveSizeVal)
        lastDivBullRegBar := bar_index

    if divBearReg and not na(pricePH) and barstate.isconfirmed and
         (na(lastDivBearRegBar) or bar_index - lastDivBearRegBar > divLabelCooldown)
        label.new(bar_index - divLB, high[divLB],
             "ūüďź RegDiv‚Üď\n" + str.tostring(divBearRegCount) + "/3",
             color = color.new(color.red, 20), textcolor = color.white,
             style = label.style_label_down, size = adaptiveSizeVal)
        lastDivBearRegBar := bar_index

    if divBullHid and not na(pricePL) and barstate.isconfirmed and
         (na(lastDivBullHidBar) or bar_index - lastDivBullHidBar > divLabelCooldown)
        label.new(bar_index - divLB, low[divLB],
             "ūüĒĀ HidDiv‚ÜĎ",
             color = color.new(color.teal, 30), textcolor = color.white,
             style = label.style_label_up, size = adaptiveSizeVal)
        lastDivBullHidBar := bar_index

    if divBearHid and not na(pricePH) and barstate.isconfirmed and
         (na(lastDivBearHidBar) or bar_index - lastDivBearHidBar > divLabelCooldown)
        label.new(bar_index - divLB, high[divLB],
             "ūüĒĀ HidDiv‚Üď",
             color = color.new(color.orange, 30), textcolor = color.white,
             style = label.style_label_down, size = adaptiveSizeVal)
        lastDivBearHidBar := bar_index

// ============================================================================
//  ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚Ėą‚ēó   ‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēó     ‚Ėą‚Ėą‚ēó   ‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚Ėą‚ēó   ‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó
// ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēź‚ēź‚ēĚ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēź‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚Ėą‚Ėą‚ēó  ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēź‚ēź‚ēĚ‚Ėą‚Ėą‚ēĎ     ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēź‚ēź‚ēĚ‚Ėą‚Ėą‚Ėą‚Ėą‚ēó  ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēź‚ēź‚ēĚ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēź‚ēź‚ēĚ
// ‚Ėą‚Ėą‚ēĎ     ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĒ‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó  ‚Ėą‚Ėą‚ēĎ     ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó  ‚Ėą‚Ėą‚ēĒ‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ     ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó
// ‚Ėą‚Ėą‚ēĎ     ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ‚ēö‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēĚ  ‚Ėą‚Ėą‚ēĎ     ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēĚ  ‚Ėą‚Ėą‚ēĎ‚ēö‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ     ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēĚ
// ‚ēö‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó‚ēö‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ‚Ėą‚Ėą‚ēĎ ‚ēö‚Ėą‚Ėą‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ     ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó‚ēö‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĎ ‚ēö‚Ėą‚Ėą‚Ėą‚Ėą‚ēĎ‚ēö‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó
//  ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ ‚ēö‚ēź‚ēĚ  ‚ēö‚ēź‚ēź‚ēź‚ēĚ‚ēö‚ēź‚ēĚ     ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ‚ēö‚ēź‚ēĚ  ‚ēö‚ēź‚ēź‚ēź‚ēĚ ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ
//  GRUB 3 ‚ÄĒ CONFLUENCE SCORING ENGINE (v6.5.0 ‚ÄĒ Fixed, Upgraded, Perfected)
// ============================================================================
// Setiap komponen menyumbang poin ke Bull atau Bear Score.
// Komponen yang sudah masuk:
//   EMA Ribbon (2), SuperTrend (2), Ichimoku Cloud (2), Chikou Span (1),
//   ADX/DI (2), RSI (2), MACD (2), Stochastic (2), CCI (1),
//   Volume/OBV (2), Bollinger Bands (2), PSAR (1), Market Structure (2),
//   MTF Alignment (max 4), BOS/CHoCH (2), Fibonacci Zone (1),
//   HSNF (2), S/R Proximity (1), TC1D Volume (1), Oscillator Matrix (1),
//   FVG (max 2), Liquidity Sweep (2), Divergence (max 3),
//   HTF Dominance Proxy (1)
// TOTAL MAX SCORE: 43 poin per sisi (bull atau bear)
// Tier: STRONG ‚Č• 18 (+ BOS/CHoCH + MTF aligned), GOOD 13-17, WEAK 9-12, LOW < 9
// ============================================================================

// ‚ĒÄ‚ĒÄ BULL SCORE ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ

// EMA Ribbon: Full alignment (8>21>50 + above 200) = 2pts, partial (8>21) = 1pt
bull_ema      = emaLongBias          ? 2 : (ema8 > ema21 ? 1 : 0)

// SuperTrend: Bullish direction (price above ST) = 2pts
bull_st       = stBull               ? 2 : 0

// Ichimoku Cloud: Price above full cloud = 2pts, TK bullish cross = 1pt
bull_ichi     = ichiAboveCloud       ? 2 : (tenkan > kijun ? 1 : 0)

// Chikou Span: Close above close[26] = bullish lagging confirmation = 1pt
bull_chikou   = chikouBull           ? 1 : 0

// ADX / DI: Jika filter ADX aktif, gunakan adxBull (DI+ > DI- + ADX strong) = 2pts;
//           jika tidak aktif, gunakan raw ADX strength saja = 1pt (fallback).
//           FIX v6.5: Pisahkan gating i_showADX dari score fallback agar
//           ADX raw tetap berkontribusi 1pt walau filter dinonaktifkan.
bull_adx      = i_showADX ? (adxBull ? 2 : (adxVal > i_adxThresh ? 1 : 0))
                           : (adxVal > i_adxThresh ? 1 : 0)

// RSI: Oversold bounce (‚Č§ rsiOS level, high-quality reversal) = 2pts,
//      Bull zone (50 < RSI < OB) = 1pt
bull_rsi      = rsiOS                ? 2 : (rsiBullZone ? 1 : 0)

// MACD: Bullish cross (momentum shift) = 2pts, MACD above signal & 0 = 1pt
bull_macd     = macdCrossUp          ? 2 : (macdBull ? 1 : 0)

// Stochastic: OS crossover (reversal signal) = 2pts, above midline = 1pt
bull_stoch    = stochBull            ? 2 : (stochMid ? 1 : 0)

// CCI: FIX v6.5.3-r3 ‚ÄĒ Zone 0‚Äď100 = bullish momentum (tidak extreme).
//      Nilai > 100 sudah overbought, tidak layak diberi poin bullish.
//      CCI < 0 tidak memberi poin bull. Changed >= to > to prevent overlap at CCI=0.
bull_cci      = (cciVal > 0 and cciVal <= 100) ? 1 : 0

// Volume / OBV: Volume bullish + spike konfirmasi = 2pts; volume bullish tanpa spike = 1pt;
//             fallback ke OBV jika harga tidak menunjukkan candle bullish volume.
bull_vol      = volBull ? (volSpike ? 2 : 1) : (obvBull ? 1 : 0)

// Bollinger Bands: Close menyentuh/menembus BB bawah (oversold squeeze) = 2pts,
//                 close di atas midline & expanding = 1pt
bull_bb       = close <= bbLo        ? 2 : (bbBull ? 1 : 0)

// Parabolic SAR: Close di atas SAR = bullish trailing = 1pt
bull_psar     = psarBull             ? 1 : 0

// Market Structure: Bullish structure terkonfirmasi (msBullish) = 2pts,
//                  Higher High + Higher Low terdeteksi = 1pt (struktur awal)
bull_ms       = msBullish            ? 2 : (hhDetected and hlDetected ? 1 : 0)

// MTF Alignment: Semua 3 HTF aligned (full bull) = 2 √ó weight (max 4),
//               ‚Č•2/3 HTF aligned = 1 √ó weight (max 4). Hard cap 4 poin.
bull_mtf      = math.min(mtfFullBull ? 2 * i_mtfWeight : (mtfBullAlign ? 1 * i_mtfWeight : 0), 4)

// BOS / CHoCH: Break of Structure atau Change of Character ke atas = 2pts
bull_bos      = (bosUp or chochUp)   ? 2 : 0

// Fibonacci Retracement Zone: FIX v6.5.3-r3 ‚ÄĒ Bull Fib zone adalah 0.382‚Äď0.618
//   (golden zone pullback untuk entry long). Changed < to <= to prevent boundary gap at 0.618.
bull_fib      = (close >= fib382 and close <= fib618) ? 1 : 0

// HSNF (Hyper-Spectral Neural Flow): Full bull stack (fast>med>slow + above slow) = 2pts,
//                                    Partial (fast>med + above med) = 1pt
bull_hsnf     = hsnfBull             ? 2 : (hsnfBullWeak ? 1 : 0)

// Support / Resistance: Close mendekati level support terdekat = 1pt
bull_sr       = srNearSupport        ? 1 : 0

// TC1D Volume Signal: Bullish price-volume konfirmasi (rebound + volume + above VWAP) = 1pt
bull_tc1d     = tc1dBull             ? 1 : 0

// Oscillator Matrix: ‚Č•2/3 sub-oscillator vote bullish = 1pt
bull_osc      = oscBull              ? 1 : 0

// Fair Value Gap (FVG): Unmitigated bullish FVG aktif (price magnet ke atas) = max 2pts
bull_fvg      = fvgBullScoreCapped

// Liquidity Sweep: Bull sweep + volume spike (institusional absorption) = 2pts,
//                 Bull sweep tanpa volume konfirmasi = 1pt
bull_liqsweep = liqSweepBullConf     ? 2 : (liqSweepBull ? 1 : 0)

// Divergence Engine: Regular divergence bullish (reversal) = 2pts,
//                   Hidden divergence bullish (continuation) = +1pt. Max 3pts.
bull_div      = divBullScore

// HTF Dominance Proxy: HTF3 (Daily) + HTF2 (4H) keduanya bullish = dominance = 1pt
bull_dom      = htfDominanceBull     ? 1 : 0

// ‚ĒÄ‚ĒÄ BULL TOTAL ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
bullScore = bull_ema + bull_st + bull_ichi + bull_chikou + bull_adx + bull_rsi + bull_macd + bull_stoch + bull_cci + bull_vol + bull_bb + bull_psar + bull_ms + bull_mtf + bull_bos + bull_fib + bull_hsnf + bull_sr + bull_tc1d + bull_osc + bull_fvg + bull_liqsweep + bull_div + bull_dom

// ‚ĒÄ‚ĒÄ BEAR SCORE ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ

// EMA Ribbon: Full short alignment (8<21<50 + below 200) = 2pts, partial (8<21) = 1pt
bear_ema      = emaShortBias         ? 2 : (ema8 < ema21 ? 1 : 0)

// SuperTrend: Bearish direction (price below ST) = 2pts
bear_st       = stBear               ? 2 : 0

// Ichimoku Cloud: Price below full cloud = 2pts, TK bearish cross = 1pt
bear_ichi     = ichiBelowCloud       ? 2 : (tenkan < kijun ? 1 : 0)

// Chikou Span: Close below close[26] = bearish lagging confirmation = 1pt
bear_chikou   = chikouBear           ? 1 : 0

// ADX / DI: Jika filter ADX aktif, gunakan adxBear (DI- > DI+ + ADX strong) = 2pts;
//           Fallback ke raw ADX strength = 1pt.
//           FIX v6.5: Konsisten dengan logika bull_adx.
bear_adx      = i_showADX ? (adxBear ? 2 : (adxVal > i_adxThresh ? 1 : 0))
                           : (adxVal > i_adxThresh ? 1 : 0)

// RSI: Overbought (‚Č• rsiOB level, reversal signal) = 2pts,
//      Bear zone (OS < RSI < 50) = 1pt
bear_rsi      = rsiOB                ? 2 : (rsiBearZone ? 1 : 0)

// MACD: Bearish cross (momentum shift down) = 2pts, MACD below signal & 0 = 1pt
bear_macd     = macdCrossDown        ? 2 : (macdBear ? 1 : 0)

// Stochastic: OB crossover down (reversal signal) = 2pts, below midline = 1pt
bear_stoch    = stochBear            ? 2 : (not stochMid ? 1 : 0)

// CCI: FIX v6.5.3-r3 ‚ÄĒ Zone -100‚Äď0 = bearish momentum (tidak extreme).
//      Nilai < -100 sudah extreme oversold, tidak layak diberi poin bearish.
//      CCI > 0 tidak memberi poin bear. Changed <= to < to prevent overlap at CCI=0.
bear_cci      = (cciVal < 0 and cciVal >= -100) ? 1 : 0

// Volume / OBV: Volume bearish + spike konfirmasi = 2pts; volume bearish tanpa spike = 1pt;
//             fallback ke OBV jika harga tidak menunjukkan candle bearish volume.
bear_vol      = volBear ? (volSpike ? 2 : 1) : (obvBear ? 1 : 0)

// Bollinger Bands: Close menyentuh/menembus BB atas (overbought squeeze) = 2pts,
//                 close di bawah midline & expanding = 1pt
bear_bb       = close >= bbUp        ? 2 : (bbBear ? 1 : 0)

// Parabolic SAR: Close di bawah SAR = bearish trailing = 1pt
bear_psar     = psarBear             ? 1 : 0

// Market Structure: Bearish structure terkonfirmasi (msBearish) = 2pts,
//                  Lower Low + Lower High terdeteksi = 1pt (struktur awal)
bear_ms       = msBearish            ? 2 : (llDetected and lhDetected ? 1 : 0)

// MTF Alignment: Semua 3 HTF aligned (full bear) = 2 √ó weight (max 4),
//               ‚Č•2/3 HTF aligned = 1 √ó weight (max 4). Hard cap 4 poin.
bear_mtf      = math.min(mtfFullBear ? 2 * i_mtfWeight : (mtfBearAlign ? 1 * i_mtfWeight : 0), 4)

// BOS / CHoCH: Break of Structure atau Change of Character ke bawah = 2pts
bear_bos      = (bosDown or chochDown) ? 2 : 0

// Fibonacci Retracement Zone: FIX v6.5 ‚ÄĒ Bear Fib zone adalah 0.618‚Äď0.786
//   (resistance zone untuk entry short / rejection dari overhead fib).
//   Sebelumnya salah: identik dengan bull_fib (382-618).
bear_fib      = (close > fib618 and close <= fib786) ? 1 : 0

// HSNF (Hyper-Spectral Neural Flow): Full bear stack (fast<med<slow + below slow) = 2pts,
//                                    Partial (fast<med + below med) = 1pt
bear_hsnf     = hsnfBear             ? 2 : (hsnfBearWeak ? 1 : 0)

// Support / Resistance: Close mendekati level resistance terdekat = 1pt
bear_sr       = srNearResist         ? 1 : 0

// TC1D Volume Signal: Bearish price-volume konfirmasi (drop + volume + below VWAP) = 1pt
bear_tc1d     = tc1dBear             ? 1 : 0

// Oscillator Matrix: ‚Č•2/3 sub-oscillator vote bearish = 1pt
bear_osc      = oscBear              ? 1 : 0

// Fair Value Gap (FVG): Unmitigated bearish FVG aktif (price magnet ke bawah) = max 2pts
bear_fvg      = fvgBearScoreCapped

// Liquidity Sweep: Bear sweep + volume spike (institusional distribution) = 2pts,
//                 Bear sweep tanpa volume konfirmasi = 1pt
bear_liqsweep = liqSweepBearConf     ? 2 : (liqSweepBear ? 1 : 0)

// Divergence Engine: Regular divergence bearish (reversal) = 2pts,
//                   Hidden divergence bearish (continuation) = +1pt. Max 3pts.
bear_div      = divBearScore

// HTF Dominance Proxy: HTF3 (Daily) + HTF2 (4H) keduanya bearish = dominance = 1pt
bear_dom      = htfDominanceBear     ? 1 : 0

// ‚ĒÄ‚ĒÄ BEAR TOTAL ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
bearScore = bear_ema + bear_st + bear_ichi + bear_chikou + bear_adx + bear_rsi + bear_macd + bear_stoch + bear_cci + bear_vol + bear_bb + bear_psar + bear_ms + bear_mtf + bear_bos + bear_fib + bear_hsnf + bear_sr + bear_tc1d + bear_osc + bear_fvg + bear_liqsweep + bear_div + bear_dom

// ============================================================================
// CONFLUENCE TIER CLASSIFICATION (v6.5.0 ‚ÄĒ Recalibrated Thresholds)
// ============================================================================
// Max possible score per sisi: 43 poin.
// Thresholds dikalibrasi ulang berdasarkan max 43 (bukan ~22 di versi lama):
//
//   STRONG ūüíé : ‚Č• 18 poin + BOS/CHoCH terkonfirmasi + MTF aligned (arah sama)
//   GOOD ‚úÖ   : 13‚Äď17 poin
//   WEAK ‚ö†ÔłŹ   :  9‚Äď12 poin
//   LOW ‚ĚĆ    :  < 9 poin
//
// Catatan: STRONG mensyaratkan BOS/CHoCH yang SEARAH dengan sisi dominan
//          (bukan hanya ada BOS/CHoCH apapun), mencegah false strong signals
//          saat struktur berlawanan muncul bersamaan.
// ============================================================================

activeScore = bullScore > bearScore ? bullScore : bearScore
isBullDom   = bullScore > bearScore   // true = bull dominant only (strict)

// FIX v6.5: BOS/CHoCH harus searah dengan sisi dominan untuk unlock STRONG tier.
// Sebelumnya: bosOrChoch = any BOS/CHoCH tanpa memperhatikan arah.
bosOrChochBull = bosUp   or chochUp
bosOrChochBear = bosDown or chochDown
bosOrChoch     = bosOrChochBull or bosOrChochBear  // backward-compat untuk Grub lain

// Directional BOS/CHoCH gate: harus searah dengan sisi dominan.
directedBosChoch = isBullDom ? bosOrChochBull : bosOrChochBear

// MTF alignment searah dengan sisi dominan.
mtfAligned    = isBullDom ? mtfBullAlign : mtfBearAlign
mtfAlignedAny = mtfBullAlign or mtfBearAlign  // backward-compat

// ‚ĒÄ‚ĒÄ Hold Duration Tier (berdasarkan trading mode) ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
holdTier1 = modeDay ? "Short: 2-8 hrs" : modeSwing ? "Mid: 1-5 days" : "Long: 1-4 weeks"
holdTier2 = modeDay ? "Mid: 8-24 hrs" : modeSwing ? "Mid: 3-10 days" : "Long: 2-8 weeks"
holdTier3 = modeDay ? "Long: 1-3 days" : modeSwing ? "Long: 1-4 weeks" : "Long: 1-6 months"

// Hold Duration berdasarkan score (thresholds disesuaikan dengan max 43)
holdDuration = activeScore >= 18 ? holdTier3 :
               activeScore >= 13 ? holdTier2 : holdTier1

// ‚ĒÄ‚ĒÄ Signal Tier (Recalibrated v6.5.0) ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
signalTier = activeScore >= 18 and directedBosChoch and mtfAligned ? "STRONG ūüíé" :
             activeScore >= 13 ?                                      "GOOD ‚úÖ"   :
             activeScore >=  9 ?                                      "WEAK ‚ö†ÔłŹ"   :
                                                                      "LOW ‚ĚĆ"

// ‚ĒÄ‚ĒÄ Signal Tier Color ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
signalTierColor = activeScore >= 18 and directedBosChoch and mtfAligned ? color.new(color.yellow, 10) : activeScore >= 13 ? color.new(color.lime, 20) : activeScore >= 9 ? color.new(color.orange, 20) : color.new(color.red, 30)

// ‚ĒÄ‚ĒÄ Net Confluence ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
netScore = bullScore - bearScore

// FIX v6.5: confluenceStr kini menampilkan score pada semua kondisi termasuk tied.
confluenceStr = bullScore > bearScore ? "BULLISH " + str.tostring(bullScore) : bearScore > bullScore ? "BEARISH " + str.tostring(bearScore) : "NEUTRAL =" + str.tostring(bullScore)

// ============================================================================
// ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚Ėą‚ēó   ‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚ēó      ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó  ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó
// ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēź‚ēź‚ēĚ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēź‚ēź‚ēĚ ‚Ėą‚Ėą‚Ėą‚Ėą‚ēó  ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĎ     ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēź‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēź‚ēź‚ēĚ ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēź‚ēź‚ēĚ
// ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ  ‚Ėą‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĒ‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ     ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ  ‚Ėą‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ
// ‚ēö‚ēź‚ēź‚ēź‚ēź‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ‚ēö‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ     ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ
// ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ‚ēö‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ‚Ėą‚Ėą‚ēĎ ‚ēö‚Ėą‚Ėą‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ  ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó‚ēö‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ‚ēö‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ‚Ėą‚Ėą‚ēĎ‚ēö‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó
// ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ‚ēö‚ēź‚ēĚ ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ ‚ēö‚ēź‚ēĚ  ‚ēö‚ēź‚ēź‚ēź‚ēĚ‚ēö‚ēź‚ēĚ  ‚ēö‚ēź‚ēĚ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ  ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ ‚ēö‚ēź‚ēĚ ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ
//  GRUB 4 ‚ÄĒ SIGNALOGIC (v6.5.0 ‚ÄĒ Fixed, Upgraded, Perfected)
// ============================================================================

// ============================================================================
// SECTION 1: POSITION STATE
// ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
// Dideklarasikan di sini (Grub 4) sebagai sumber kebenaran tunggal.
// Digunakan oleh Grub 3 (Confluence), Grub 5 (Strategy), Grub 6 (Visualization),
// Grub 7 (Dashboard), dan Grub 8 (Alerts).
// PENTING: Harus dideklarasikan SEBELUM longCondition/shortCondition karena
//          beberapa exit guard di longCondition bergantung pada state ini.
// ============================================================================

inLong  = strategy.position_size > 0
inShort = strategy.position_size < 0

// ============================================================================
// SECTION 2: PERSISTENT BAR-STATE TRACKERS
// ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
// Semua var yang butuh persistensi lintas bar dideklarasikan di sini.
// Di-update oleh Grub 5 (Strategy) setelah eksekusi order.
// ============================================================================

// Cooldown trackers: menyimpan bar_index terakhir entry/exit masing-masing arah
var int lastLongBar      = na  // Bar index terakhir long entry
var int lastShortBar     = na  // Bar index terakhir short entry
var int lastExitBar      = na  // Bar index terakhir posisi ditutup (SL, TP, reversal)
var int lastExitLongBar  = na  // Bar index terakhir exit long ditutup
var int lastExitShortBar = na  // Bar index terakhir exit short ditutup

// Per-bar exit guard: direset tiap bar, di-set true oleh Grub 5 saat exit terjadi
// Mencegah entry baru di bar yang sama dengan exit (look-ahead bias)
var bool exitHappenedThisBar = false
var bool longWasOpen  = false
var bool shortWasOpen = false

exitHappenedThisBar := false  // Reset di awal tiap bar ‚ÄĒ WAJIB baris pertama ini

longJustClosed  = longWasOpen  and not inLong
shortJustClosed = shortWasOpen and not inShort

longWasOpen  := inLong
shortWasOpen := inShort

if longJustClosed or shortJustClosed
    exitHappenedThisBar := true

// ============================================================================
// SECTION 3: FILTER PASSES
// ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
// Filter aktif/nonaktif dievaluasi sekali per bar.
// Dipisahkan agar mudah di-debug dan transparan di dashboard.
// ============================================================================

// ADX Filter: Jika aktif, trend harus cukup kuat (ADX ‚Č• threshold)
adxPass = not i_filterADX or adxStrong

// Volume Filter: Jika aktif, harus ada konfirmasi volume (spike atau di atas MA)
// FIX v6.5: volPass kini DIGUNAKAN dalam longCondition/shortCondition (sebelumnya
//            dideklarasikan tapi tidak digunakan ‚ÄĒ logic gap serius).
volPass = not i_filterVolume or volSpike or (volume > volMA * i_volConfirmMult)

// MTF Alignment Filter: Jika aktif, HTF harus aligned searah sinyal
mtfBullPass = not i_reqMTFAlign or mtfBullAlign
mtfBearPass = not i_reqMTFAlign or mtfBearAlign

// ============================================================================
// SECTION 4: COOLDOWN LOGIC
// ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
// Mencegah over-trading dan flip-flopping pada kondisi choppy.
// Cooldown dikalibrasi per Trading Mode untuk keseimbangan optimal.
// ============================================================================

// Cooldown minimum antar entry SEARAH (same direction)
// Day: 3 bars | Swing: 10 bars | Position: 20 bars
cooldownBars = modeDay ? 3 : modeSwing ? 10 : 20

// Cooldown minimum antar entry BERLAWANAN arah setelah exit
// Day: 1 bar | Swing: 3 bars | Position: 5 bars
// FIX v6.5: Memperketat crossDirCooldown swing dari 3‚Üí4 untuk menghindari
//           premature reversal di crypto yang sangat volatile.
crossDirCooldown = modeDay ? 1 : modeSwing ? 4 : 5

// Evaluasi cooldown: true = boleh entry
longCooldownOK  = na(lastLongBar)  or (bar_index - lastLongBar  >= cooldownBars)
shortCooldownOK = na(lastShortBar) or (bar_index - lastShortBar >= cooldownBars)

// Cross-directional cooldown: arah-specific
crossDirOKLong  = na(lastExitShortBar) or (bar_index - lastExitShortBar >= crossDirCooldown)
crossDirOKShort = na(lastExitLongBar)  or (bar_index - lastExitLongBar  >= crossDirCooldown)

// ============================================================================
// SECTION 5: ENTRY CONDITIONS (LONG & SHORT)
// ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
// Logic Utama:
//   1. Confluence score memenuhi minimum threshold
//   2. Sisi dominan memiliki keunggulan lebih dari 1 poin (margin > 1)
//   3. ADX filter pass (trend cukup kuat)
//   4. Volume filter pass (FIX: sekarang aktif di conditions)
//   5. Session filter pass (dalam jam trading yang diizinkan)
//   6. MTF alignment pass (sesuai setting i_reqMTFAlign)
//   7. Minimal 1 trigger katalitik: momentum event yang memicu sinyal
//      (MACD cross, Stoch crossover, BOS, CHoCH, TK cross, Liq Sweep, Divergence)
//   8. Cooldown OK (tidak ada entry terlalu cepat setelah entry/exit sebelumnya)
//   9. Tidak ada exit yang terjadi di bar yang sama (anti look-ahead)
//  10. Tidak sedang dalam posisi aktif berlawanan arah
//
// Catatan: Persyaratan trigger katalitik (poin 7) sangat penting untuk
//          memastikan kita tidak masuk hanya dari score pasif (lagging indicators),
//          tetapi harus ada momentum event yang aktif dan baru terjadi.
// ============================================================================

longCondition = bullScore >= minConfl        and  // Score minimum terpenuhi
     bullScore > bearScore + 1               and  // Dominansi bull jelas (margin > 1)
     adxPass                                 and  // Trend cukup kuat
     volPass                                 and  // Volume konfirmasi (FIX: aktif)
     sessionOK                               and  // Dalam jam trading
     mtfBullPass                             and  // HTF alignment (jika diaktifkan)
     not inShort                             and  // Tidak dalam posisi short aktif
     (macdCrossUp  or                             // Trigger: MACD bullish crossover
      stochBull    or                             // Trigger: Stochastic oversold crossover
      bosUp        or                             // Trigger: Break of Structure ke atas
      chochUp      or                             // Trigger: Change of Character bullish
      ichiTKCross  or                             // Trigger: Ichimoku TK bullish cross
      liqSweepBull or                             // Trigger: Liquidity sweep bullish
      divBullReg)                            and  // Trigger: Regular bullish divergence
     longCooldownOK                             and  // Cooldown same-direction OK
     crossDirOKLong                              and  // Cooldown cross-direction OK
     not exitHappenedThisBar                      // Tidak exit di bar yang sama

// Hitung jumlah trigger bearish aktif (digunakan untuk mengurangi false-short spam)
shortTriggers = (macdCrossDown ? 1 : 0) + (stochBear ? 1 : 0) + (bosDown ? 1 : 0) + (chochDown ? 1 : 0) + (ichiTKDeath ? 1 : 0) + (liqSweepBear ? 1 : 0) + (divBearReg ? 1 : 0)

// Tentukan jumlah trigger yang diperlukan: jika boolean legacy aktif, paksa 2, else gunakan input numerik
requiredShortTriggers = i_shortRequireDouble ? 2 : i_shortTriggerMin

shortCondition = bearScore >= minConfl       and  // Score minimum terpenuhi
     bearScore > bullScore + 1               and  // Dominansi bear jelas (margin > 1)
     adxPass                                 and  // Trend cukup kuat
     volPass                                 and  // Volume konfirmasi (FIX: aktif)
     sessionOK                               and  // Dalam jam trading
     mtfBearPass                             and  // HTF alignment (jika diaktifkan)
     not inLong                              and  // Tidak dalam posisi long aktif
     shortTriggers >= requiredShortTriggers and  // Trigger: minimal 1/2/lebih sesuai pengaturan
     shortCooldownOK                            and  // Cooldown same-direction OK
     crossDirOKShort                             and  // Cooldown cross-direction OK
     not exitHappenedThisBar                      // Tidak exit di bar yang sama

// ‚ĒÄ‚ĒÄ Entry Signal Aliases (digunakan oleh Grub 6 Visualization & Grub 8 Alerts) ‚ĒÄ‚ĒÄ
entryLongSignal  = longCondition
entryShortSignal = shortCondition

// ============================================================================
// SECTION 6: HOLD CONDITIONS
// ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
// Hold condition: sudah dalam posisi aktif, skor masih mendukung, namun
// belum memenuhi syarat entry baru. Digunakan sebagai konfirmasi visual
// untuk trader agar tidak exit prematur.
// FIX v6.5: Ditambah guard `not inLong` / `not inShort` agar HOLD label
//           tidak muncul saat memang sudah dalam posisi (mengurangi noise).
// ============================================================================

longHold = bullScore >= math.max(minConfl - 1, 1) and
     bullScore > bearScore                         and
     not longCondition                             and
     not inShort                                   and
     (stBull or emaLongBias)

shortHold = bearScore >= math.max(minConfl - 1, 1) and
     bearScore > bullScore                          and
     not shortCondition                             and
     not inLong                                     and
     (stBear or emaShortBias)

// ============================================================================
// SECTION 7: STOP LOSS CALCULATION
// ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
// Tiga tipe SL yang tersedia (dipilih via input):
//   ATR    : SL = entry ¬Ī (ATR √ó mode multiplier) ‚ÄĒ dinamis, mengikuti volatilitas
//   Swing  : SL = swing terdekat ¬Ī 1 ATR buffer   ‚ÄĒ struktural, menghindari manipulation
//   Fixed %: SL = persentase tetap dari entry      ‚ÄĒ sederhana, deterministik
//
// FIX v6.5: Ditambah guard math.max/math.min untuk memastikan:
//   - Long SL selalu < entry (tidak di atas harga masuk)
//   - Short SL selalu > entry (tidak di bawah harga masuk)
//   - Mencegah invalid SL pada aset harga sangat rendah
// ============================================================================

getSwingLow (len) => ta.lowest (low,  len)
getSwingHigh(len) => ta.highest(high, len)

calcSLLong(entryPx) =>
    rawSL = i_slType == "ATR" ? entryPx - atrModeMultSL * atrVal : i_slType == "Swing" ? math.min(getSwingLow(swingLen * 2), entryPx - atrVal) : entryPx * (1.0 - i_slFixedPct / 100.0)
    // Guard: SL long harus strictly di bawah entry, minimal 1 tick
    math.min(rawSL, entryPx - syminfo.mintick)

calcSLShort(entryPx) =>
    rawSL = i_slType == "ATR" ? entryPx + atrModeMultSL * atrVal : i_slType == "Swing" ? math.max(getSwingHigh(swingLen * 2), entryPx + atrVal) : entryPx * (1.0 + i_slFixedPct / 100.0)
    // Guard: SL short harus strictly di atas entry, minimal 1 tick
    math.max(rawSL, entryPx + syminfo.mintick)

// ============================================================================
// SECTION 8: TAKE PROFIT CALCULATION
// ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
// TP dihitung dari risk (selisih entry - SL) √ó RR multiplier.
// Mendukung 3 level: TP1 (50%), TP2 (30%), TP3 (trail 20%).
// Dynamic RR dari dynRRBoost (Grub 2) sudah ter-apply di tp1Mode/tp2Mode/tp3Mode.
// ============================================================================

calcTP(entryPx, slPx, rrMult, isLong) =>
    risk   = math.abs(entryPx - slPx)
    target = isLong ? entryPx + rrMult * risk : entryPx - rrMult * risk
    // Guard: TP long harus > entry, TP short harus < entry
    isLong ? math.max(target, entryPx + syminfo.mintick)
           : math.min(target, entryPx - syminfo.mintick)

// ============================================================================
// SECTION 9: TRAILING STOP CALCULATION
// ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
// Dua tipe trailing yang tersedia:
//   ATR          : trail = highest/lowest ¬Ī (ATR √ó trail multiplier)
//   Parabolic SAR: trail = nilai PSAR aktif (dari Grub 2)
//
// FIX v6.5: Ditambah na-guard pada parameter input `px` untuk mencegah
//           kalkulasi trail menghasilkan na saat posisi baru dibuka.
// ============================================================================

updateTrailLong(px) =>
    if na(px)
        na
    else
        trailAtr  = px - i_trailATRMult * atrVal
        trailPsar = psarVal
        i_trailType == "Parabolic SAR" ? trailPsar : trailAtr

updateTrailShort(px) =>
    if na(px)
        na
    else
        trailAtr  = px + i_trailATRMult * atrVal
        trailPsar = psarVal
        i_trailType == "Parabolic SAR" ? trailPsar : trailAtr

// ============================================================================
// SECTION 10: POSITION SIZING
// ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
// Kalkulasi ukuran posisi berbasis risiko (Risk-Based Position Sizing):
//   qty = (AccountSize √ó RiskPercent%) / riskPerUnit
//   riskPerUnit = |entry - SL|  (risiko aktual per unit aset)
//
// Pengamanan bertingkat:
//   1. riskPerUnit floored ke 0.1% dari entryPx ‚ÄĒ mencegah division near-zero
//      (terjadi saat SL terlalu dekat entry, misalnya Fixed % yang sangat kecil)
//   2. maxQtyByAccount: batas atas logis berdasarkan kapasitas akun (accountSize / entryPx)
//   3. maxQtyCap: absolute upper cap = 5√ó account capacity ‚ÄĒ lebih konservatif dari
//      versi lama (10√ó) untuk menghindari oversized position pada aset harga sangat rendah
//   4. minQtyGuard: pastikan qty ‚Č• 1 unit minimum ‚ÄĒ mencegah strategy.entry(qty=0)
//      yang menyebabkan runtime error di TradingView
//
// FIX v6.5: minQtyGuard ditambahkan (sebelumnya tidak ada ‚ÄĒ qty bisa = 0),
//           maxQtyCap dikurangi dari 10√ó ke 5√ó untuk safety,
//           riskPerUnit floor diperketat dari 0.1% ke lebih eksplisit.
// ============================================================================

calcPositionSize(entryPx, slPx) =>
    // Risk dalam USD
    riskAmount  = i_accountSize * i_riskPercent / 100.0
    // Risk per unit: minimal 0.1% dari entryPx ATAU 10x mintick sebagai floor (anti division-by-zero)
    // Floor ganda mencegah riskPerUnit terlalu kecil pada aset harga sangat rendah
    riskPerUnit = math.max(math.abs(entryPx - slPx), math.max(entryPx * 0.001, syminfo.mintick * 10))
    // Kalkulasi qty berbasis risiko (raw)
    rawQty      = riskAmount / riskPerUnit
    // Batas atas logis: berapa unit yang bisa dibeli dengan full account
    maxQtyByAccount = i_accountSize / math.max(entryPx, 0.000001)
    // Hard cap: maksimal i_leverage √ó account capacity (FIX v6.5.3-r3: configurable, was hardcoded 5√ó)
    maxQtyCap   = maxQtyByAccount * i_leverage
    // Floor: minimal 1 unit untuk mencegah strategy.entry(qty=0) error
    minQty      = math.max(1.0 / math.max(entryPx, 0.000001), 0.000001)
    // Final qty: dibatasi antara minQty dan maxQtyCap
    qty         = math.max(math.min(rawQty, maxQtyCap), minQty)
    qty

// ============================================================================
// ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó  ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēó   ‚Ėą‚Ėą‚ēó
// ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēź‚ēź‚ēĚ‚ēö‚ēź‚ēź‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēĚ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēó‚ēö‚ēź‚ēź‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēĚ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēź‚ēź‚ēĚ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēź‚ēź‚ēĚ‚ēö‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚ēĒ‚ēĚ
// ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó   ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó  ‚Ėą‚Ėą‚ēĎ  ‚Ėą‚Ėą‚Ėą‚ēó‚ēö‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ
// ‚ēö‚ēź‚ēź‚ēź‚ēź‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēĚ  ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ ‚ēö‚Ėą‚Ėą‚ēĒ‚ēĚ
// ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ  ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ  ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó‚ēö‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ  ‚Ėą‚Ėą‚ēĎ
// ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ   ‚ēö‚ēź‚ēĚ   ‚ēö‚ēź‚ēĚ  ‚ēö‚ēź‚ēĚ‚ēö‚ēź‚ēĚ  ‚ēö‚ēź‚ēĚ   ‚ēö‚ēź‚ēĚ   ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ   ‚ēö‚ēź‚ēĚ
//  GRUB 5 ‚ÄĒ BACKTESTING ENGINE (v6.5.0 ‚ÄĒ Fixed, Upgraded, Perfected)
// ============================================================================
// Arsitektur eksekusi order AlphaEdge:
//
//  ENTRY:
//    ‚ÄĘ longCondition  ‚Üí strategy.entry(ID_LONG,  strategy.long,  qty = calcPositionSize())
//    ‚ÄĘ shortCondition ‚Üí strategy.entry(ID_SHORT, strategy.short, qty = calcPositionSize())
//    ‚ÄĘ Saat entry: registrasikan Long_Full_Exit / Short_Full_Exit (SL + TP3 100%)
//      sebagai fallback jika tidak ada partial TP yang terpicu.
//
//  PARTIAL TP (intrabar detection):
//    TP1 (50%): high >= tp1 (long) / low <= tp1 (short)
//      ‚Üí strategy.close(qty = 50%)
//      ‚Üí registrasikan Long_TP2_Exit (30%) dan ID_LONG_TRAIL (20%) dengan SL dinamis
//    TP2 (30%): high >= tp2 (long) / low <= tp2 (short), setelah TP1 hit
//      ‚Üí strategy.close(qty = 30%)
//      ‚Üí re-registrasikan ID_LONG_TRAIL (20%) dengan SL terbaru
//
//  TRAILING STOP (porsi TP3 20%):
//    ‚ÄĘ Aktif setelah TP1 hit (jika i_trailingStop aktif)
//    ‚ÄĘ currentDynamicSL hanya ratchet searah posisi (naik untuk long, turun untuk short)
//    ‚ÄĘ Floor: breakevenPrice jika breakevenActive, else SL asli
//
//  BREAKEVEN:
//    ‚ÄĘ Aktif setelah TP1 hit (jika i_breakeven aktif)
//    ‚ÄĘ currentDynamicSL di-set ke entryPrice
//
//  EXIT SINYAL REVERSAL:
//    ‚ÄĘ exitLongSignal / exitShortSignal ‚Üí strategy.close() + cancel semua exit terdaftar
//    ‚ÄĘ smartExitLong / smartExitShort  ‚Üí TK Death/Cross filter tambahan
//    ‚ÄĘ Spot: hanya exitLong (tidak ada short)
//
//  GUARD ANTI-RACE CONDITION:
//    ‚ÄĘ enteredThisBar: mencegah entry dan exit terjadi di bar yang sama
//    ‚ÄĘ longClosedByReversal / shortClosedByReversal: mencegah double-close
//    ‚ÄĘ partialClosedThisBar: mencegah TP1 + TP2 di-trigger bar yang sama
//    ‚ÄĘ exitHappenedThisBar: mencegah entry setelah exit di bar yang sama (Grub 4)
//    ‚ÄĘ lastExitBar: cross-directional cooldown (Grub 4)
//
//  STATE SYNC:
//    ‚ÄĘ prevBreakevenActive, prevLongHold, prevShortHold di-update di akhir script
//      (digunakan oleh Grub 8 ‚ÄĒ Alerts untuk edge-detection)
// ============================================================================

// ‚ĒÄ‚ĒÄ PERSISTENT STATE VARIABLES ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
var float entryPrice           = na      // Harga masuk posisi aktif
var float tp1                  = na      // Take Profit 1 level (50% close)
var float tp2                  = na      // Take Profit 2 level (30% close)
var float tp3                  = na      // Take Profit 3 level (20% trail close)
var float breakevenPrice       = na      // Entry price (referensi breakeven visual)
var float currentDynamicSL     = na      // SL dinamis yang aktif (naik/turun seiring trailing)

var float initialQtyLong       = 0.0    // Qty penuh saat long entry
var float remainingQtyLong     = 0.0    // Qty tersisa (tracking informatif)
var bool  tp1hitLong           = false  // True jika TP1 sudah terpicu pada posisi long ini
var bool  tp2hitLong           = false  // True jika TP2 sudah terpicu pada posisi long ini
var bool  breakevenActiveLong  = false  // True jika breakeven sudah aktif pada long ini
var float longSLPrice          = na      // SL awal saat long entry (tidak berubah setelah entry)

var float initialQtyShort      = 0.0    // Qty penuh saat short entry
var float remainingQtyShort    = 0.0    // Qty tersisa (tracking informatif)
var bool  tp1hitShort          = false  // True jika TP1 sudah terpicu pada posisi short ini
var bool  tp2hitShort          = false  // True jika TP2 sudah terpicu pada posisi short ini
var bool  breakevenActiveShort = false  // True jika breakeven sudah aktif pada short ini
var float shortSLPrice         = na      // SL awal saat short entry (tidak berubah setelah entry)

// Alert sent guards ‚ÄĒ mencegah alert TP duplikat per posisi
var bool  alertTP1SentLong     = false
var bool  alertTP2SentLong     = false
var bool  alertTP3SentLong     = false
var bool  alertTP1SentShort    = false
var bool  alertTP2SentShort    = false
var bool  alertTP3SentShort    = false
var bool  alertSLSentLong      = false
var bool  alertSLSentShort     = false

// State-change trackers ‚ÄĒ digunakan Grub 8 (Alerts) untuk edge detection (rising edge only)
var bool  prevBreakevenActive  = false
var bool  prevLongHold         = false
var bool  prevShortHold        = false

// Per-bar execution guards ‚ÄĒ direset tiap bar (lihat bagian reset di bawah)
var bool  partialClosedThisBar  = false  // True jika partial close sudah dilakukan bar ini
var bool  enteredThisBar        = false  // True jika entry sudah dilakukan bar ini
var bool  longClosedByReversal  = false  // True jika long sudah ditutup reversal bar ini
var bool  shortClosedByReversal = false  // True jika short sudah ditutup reversal bar ini

// Actual filled qty ‚ÄĒ di-sync dari strategy.position_size setiap bar
var float actualFilledQty      = 0.0

// Visual breakeven label
var label lblBreakeven         = na

// Strategy exit / trail change detection (mencegah re-register exit tiap bar tanpa perubahan)
var float prevDynamicSL        = na
var float prevTp3              = na

// Strategy entry/exit IDs ‚ÄĒ konstanta string untuk konsistensi cancel/exit referensi
var string ID_LONG         = "AE_LONG"
var string ID_SHORT        = "AE_SHORT"
var string ID_LONG_TRAIL   = "AE_LONG_TRAIL"
var string ID_SHORT_TRAIL  = "AE_SHORT_TRAIL"

// Tracking informasi entry terakhir dan label cooldown
var float lastEntryQty     = 0.0
var int   lastHoldLabelBar = na


// ‚ĒÄ‚ĒÄ PER-BAR RESET ‚ÄĒ wajib di awal setiap bar ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
partialClosedThisBar    := false
enteredThisBar          := false
longClosedByReversal    := false
shortClosedByReversal   := false

// ‚ĒÄ‚ĒÄ SYNC ACTUAL FILLED QTY ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
// Gunakan strategy.position_size sebagai sumber kebenaran jumlah unit aktif.
// Reset ke 0 saat flat agar kalkulasi partial close berbasis qty yang akurat.
if inLong or inShort
    actualFilledQty := math.abs(strategy.position_size)
else
    actualFilledQty := 0.0


// ‚ĒÄ‚ĒÄ GLOBAL SCOPE CALCULATIONS ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
// Hitung SL di luar blok 'if' agar time-series Pine Script tetap konsisten.
// Pine Script membutuhkan fungsi seri di-evaluate setiap bar untuk historinya valid.
temp_longSLPrice  = calcSLLong(close)
temp_shortSLPrice = calcSLShort(close)


// ‚ĒÄ‚ĒÄ MARKET TYPE GATES ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
canLong  = i_marketType == "Spot"    or
           i_marketType == "Futures" or
           i_marketType == "Both"

canShort = i_marketType == "Futures" or
           i_marketType == "Both"


// ============================================================================
// SECTION 1: LONG ENTRY
// ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
// Guard lengkap:
//   ‚ÄĘ longCondition  : skor + filter + trigger (dari Grub 4)
//   ‚ÄĘ not inLong     : tidak double-entry arah yang sama
//   ‚ÄĘ not inShort    : tidak masuk long saat masih short (tunggu exit dulu)
//   ‚ÄĘ canLong        : market type izinkan long
//   ‚ÄĘ not longClosedByReversal  : long tidak baru saja ditutup bar ini
//   ‚ÄĘ not shortClosedByReversal : short tidak baru saja ditutup bar ini
// ============================================================================
if longCondition and not inLong and not inShort and canLong and
     not longClosedByReversal and not shortClosedByReversal and
     not exitHappenedThisBar

    // Set entry price dari close bar ini
    entryPrice          := close

    // Kalkulasi SL dari fungsi (Grub 4 ‚ÄĒ calcSLLong)
    longSLPrice         := temp_longSLPrice

    // Kalkulasi tiga level TP menggunakan RR dinamis dari Grub 2 (tp1Mode/tp2Mode/tp3Mode)
    tp1                 := calcTP(entryPrice, longSLPrice, tp1Mode, true)
    tp2                 := calcTP(entryPrice, longSLPrice, tp2Mode, true)
    tp3                 := calcTP(entryPrice, longSLPrice, tp3Mode, true)

    // Inisialisasi SL dinamis = SL awal; breakevenPrice = entry (referensi visual)
    currentDynamicSL    := longSLPrice
    breakevenPrice      := entryPrice

    // Kalkulasi position sizing berbasis risiko (Grub 4 ‚ÄĒ calcPositionSize)
    initialQtyLong      := calcPositionSize(entryPrice, longSLPrice)
    remainingQtyLong    := initialQtyLong

    // Cooldown tracking dan entry guard
    lastEntryQty        := initialQtyLong
    lastLongBar         := bar_index
    enteredThisBar      := true

    // Reset seluruh state TP/BE/alert untuk posisi baru ini
    tp1hitLong          := false
    tp2hitLong          := false
    breakevenActiveLong := false
    alertTP1SentLong    := false
    alertTP2SentLong    := false
    alertTP3SentLong    := false
    alertSLSentLong     := false

    // Reset SL/TP change-detection tracker agar exit pertama pasti di-register
    prevDynamicSL       := na
    prevTp3             := na

    // Clear any stale pending exit orders from previous trades before entry.
    strategy.cancel("Long_Full_Exit")
    strategy.cancel("Long_TP2_Exit")
    strategy.cancel(ID_LONG_TRAIL)
    strategy.cancel("Short_Full_Exit")
    strategy.cancel("Short_TP2_Exit")
    strategy.cancel(ID_SHORT_TRAIL)

    // Eksekusi entry
    strategy.entry(ID_LONG, strategy.long,
         qty     = initialQtyLong,
         comment = "AE¬∑ENTRY LONG [" + signalTier + "] | Hold: " + holdDuration)

    // Batalkan trail lama jika ada (dari posisi sebelumnya yang belum ter-cancel)

    // Registrasikan exit fallback (SL + TP3 100%) untuk meng-cover full posisi.
    // Partial TP akan di-handle secara intrabar dan menggantikan exit ini.
    strategy.exit("Long_Full_Exit", from_entry = ID_LONG,
         qty_percent    = 100,
         stop           = longSLPrice,
         limit          = tp3,
         comment_profit = "TP3/Full Exit",
         comment_loss   = "SL Hit")


// ============================================================================
// SECTION 2: SHORT ENTRY
// ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
// Guard lengkap identik dengan Long Entry, mirrored untuk arah short.
// ============================================================================
if shortCondition and not inShort and not inLong and canShort and
     not shortClosedByReversal and not longClosedByReversal and
     not exitHappenedThisBar

    entryPrice           := close
    shortSLPrice         := temp_shortSLPrice

    tp1                  := calcTP(entryPrice, shortSLPrice, tp1Mode, false)
    tp2                  := calcTP(entryPrice, shortSLPrice, tp2Mode, false)
    tp3                  := calcTP(entryPrice, shortSLPrice, tp3Mode, false)

    currentDynamicSL     := shortSLPrice
    breakevenPrice       := entryPrice

    initialQtyShort      := calcPositionSize(entryPrice, shortSLPrice)
    remainingQtyShort    := initialQtyShort

    lastEntryQty         := initialQtyShort
    lastShortBar         := bar_index
    enteredThisBar       := true

    tp1hitShort          := false
    tp2hitShort          := false
    breakevenActiveShort := false
    alertTP1SentShort    := false
    alertTP2SentShort    := false
    alertTP3SentShort    := false
    alertSLSentShort     := false

    prevDynamicSL        := na
    prevTp3              := na

    strategy.cancel("Short_Full_Exit")
    strategy.cancel("Short_TP2_Exit")
    strategy.cancel(ID_SHORT_TRAIL)
    strategy.cancel("Long_Full_Exit")
    strategy.cancel("Long_TP2_Exit")
    strategy.cancel(ID_LONG_TRAIL)

    strategy.entry(ID_SHORT, strategy.short,
         qty     = initialQtyShort,
         comment = "AE¬∑ENTRY SHORT [" + signalTier + "] | Score: " + str.tostring(bearScore))



    strategy.exit("Short_Full_Exit", from_entry = ID_SHORT,
         qty_percent    = 100,
         stop           = shortSLPrice,
         limit          = tp3,
         comment_profit = "TP3/Full Exit",
         comment_loss   = "SL Hit")


// ============================================================================
// SECTION 3: EXIT SIGNAL DEFINITIONS
// ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
// Ditempatkan setelah entry agar strategy.position_size ter-update terlebih dahulu
// sebelum exit signal dievaluasi. Ini mencegah race condition entry+exit bar sama.
//
// exitLongSignal:
//   ‚ÄĘ shortCondition aktif (reversal sinyal) ATAU
//   ‚ÄĘ SuperTrend baru flip bearish (stBearFlip) ATAU
//   ‚ÄĘ bearScore > bullScore + 3 (momentum bergeser signifikan, TP1 belum hit) ATAU
//   ‚ÄĘ bearScore > bullScore + 5 (momentum bergeser kuat, TP1 sudah hit) ATAU
//   ‚ÄĘ Ichimoku TK Death Cross (ichiTKDeath)
//
// Catatan threshold asimetris TP1hitLong:
//   Setelah TP1 hit, posisi sudah profit parsial ‚ÄĒ standar exit dinaikkan (+5)
//   untuk mencegah exit prematur pada trailing 20% yang masih berjalan.
// ============================================================================
stBearFlip = stBear and not stBear[1]   // SuperTrend baru flip ke bear bar ini
stBullFlip = stBull and not stBull[1]   // SuperTrend baru flip ke bull bar ini

tkDeathEdge = ichiTKDeath   // TK Death Cross (Grub 2/3)
tkCrossEdge = ichiTKCross   // TK Bullish Cross (Grub 2/3)

exitLongSignal = inLong and not enteredThisBar and (
     shortCondition                              or   // Reversal signal penuh
     stBearFlip                                  or   // ST flip bearish
     (not tp1hitLong  and bearScore >= bullScore + 3) or  // Dominasi bear dini
     (tp1hitLong      and bearScore >= bullScore + 5) or  // Dominasi bear kuat (post-TP1)
     tkDeathEdge                                      )   // TK Death Cross

exitShortSignal = inShort and not enteredThisBar and (
     longCondition                               or   // Reversal signal penuh
     stBullFlip                                  or   // ST flip bullish
     (not tp1hitShort and bullScore >= bearScore + 3) or  // Dominasi bull dini
     (tp1hitShort     and bullScore >= bearScore + 5) or  // Dominasi bull kuat (post-TP1)
     tkCrossEdge                                      )   // TK Cross bullish


// ============================================================================
// SECTION 4: SPOT MARKET EXIT
// ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
// Spot tidak mendukung short, sehingga hanya exit long yang diterapkan.
// Dieksekusi sebelum partial TP detection agar tidak bertumpuk dengan
// partial close yang sudah terjadi di bar yang sama.
// ============================================================================
if i_marketType == "Spot" and exitLongSignal and
     not partialClosedThisBar and not enteredThisBar and not longClosedByReversal
    strategy.close(ID_LONG, comment = "AE¬∑SELL (Spot Exit) | Signal reversal")
    strategy.cancel_all()
    longClosedByReversal    := true
    lastExitBar             := bar_index
    lastExitLongBar         := bar_index
    tp1hitLong              := false
    tp2hitLong              := false
    breakevenActiveLong     := false
    exitHappenedThisBar     := true
    if i_showLabels
        label.new(bar_index, high, "SELL\nSpot Exit",
             color     = color.new(color.red, 10),
             textcolor = color.white,
             style     = label.style_label_down,
             size      = adaptiveSizeVal)


// ============================================================================
// SECTION 5: PARTIAL TP HIT DETECTION & EXECUTION
// ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
// Deteksi menggunakan intrabar price action (high/low vs level TP).
// Penting: satu kali per bar (partialClosedThisBar guard) untuk mencegah
// TP1 dan TP2 trigger sekaligus di bar yang sama.
//
// Alokasi qty berbasis actualFilledQty (strategy.position_size) jika tersedia,
// fallback ke initialQty yang tersimpan saat entry.
//
// LONG partial exits:
//   TP1 hit ‚Üí close 50% + register TP2_Exit (30%) + register Trail (20%)
//   TP2 hit ‚Üí close 30% + re-register Trail (20%) dengan SL terbaru
//
// SHORT partial exits (mirrored, kondisi reversed):
//   TP1 hit ‚Üí close 50% + register TP2_Exit (30%) + register Trail (20%)
//   TP2 hit ‚Üí close 30% + re-register Trail (20%) dengan SL terbaru
// ============================================================================

// ‚ĒÄ‚ĒÄ LONG PARTIAL TP ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
if inLong

    // TP1: price touches/exceeds TP1 level
    // FIX v6.5.3-r3: removed barstate.isconfirmed to allow intrabar execution with calc_on_every_tick
    // This significantly improves fill accuracy at TP1 level
    if not tp1hitLong and initialQtyLong > 0 and high >= tp1 and not partialClosedThisBar
        tp1hitLong           := true
        partialClosedThisBar := true

        // Cancel fallback full-exit dan trail yang mungkin tersisa dari bar sebelumnya
        strategy.cancel("Long_Full_Exit")
        strategy.cancel(ID_LONG_TRAIL)
        strategy.cancel("Long_TP2_Exit")

        // Pilih qty basis: aktual dari exchange lebih akurat dari estimasi awal
        qtyToClose = actualFilledQty > 0 ? actualFilledQty : initialQtyLong

        // Tutup 50% posisi di harga pasar (TP1 terkonfirmasi)
        strategy.close(ID_LONG,
             qty     = qtyToClose * 0.50,
             comment = "TP1 50%")

        // Registrasikan exit untuk porsi TP2 (30%) ‚ÄĒ SL dinamis + limit TP2
        strategy.exit("Long_TP2_Exit", from_entry = ID_LONG,
             qty_percent    = 30,
             stop           = currentDynamicSL,
             limit          = tp2,
             comment_profit = "TP2 30%",
             comment_loss   = "SL After TP1")

        // Registrasikan trail untuk porsi TP3 (20%) ‚ÄĒ SL dinamis + limit TP3
        strategy.exit(ID_LONG_TRAIL, from_entry = ID_LONG,
             qty_percent    = 20,
             stop           = currentDynamicSL,
             limit          = tp3,
             comment_profit = "TP3 Trail",
             comment_loss   = "SL TP3")

        if i_showLabels
            label.new(bar_index, high,
                 "‚úÖ TP1 HIT\n50% Closed",
                 color     = color.new(color.lime, 10),
                 textcolor = color.black,
                 style     = label.style_label_down,
                 size      = adaptiveSizeVal)

    // TP2: price reaches TP2 level, hanya setelah TP1 sudah terpicu
    // FIX v6.5.3-r3: removed barstate.isconfirmed for intrabar execution accuracy
    if not tp2hitLong and tp1hitLong and initialQtyLong > 0 and
         high >= tp2 and not partialClosedThisBar
        tp2hitLong           := true
        partialClosedThisBar := true



        qtyToClose = actualFilledQty > 0 ? actualFilledQty : initialQtyLong

        // Tutup 30% posisi di harga pasar (TP2 terkonfirmasi)
        strategy.close(ID_LONG,
             qty     = qtyToClose * 0.30,
             comment = "TP2 30%")

        // Re-registrasikan trail untuk 20% terakhir dengan SL terbaru (trail mungkin sudah naik)
        strategy.exit(ID_LONG_TRAIL, from_entry = ID_LONG,
             qty_percent    = 20,
             stop           = currentDynamicSL,
             limit          = tp3,
             comment_profit = "TP3 After TP2",
             comment_loss   = "SL After TP2")

        if i_showLabels
            label.new(bar_index, high,
                 "‚úÖ TP2 HIT\n80% Closed",
                 color     = color.new(color.lime, 10),
                 textcolor = color.black,
                 style     = label.style_label_down,
                 size      = adaptiveSizeVal)


// ‚ĒÄ‚ĒÄ SHORT PARTIAL TP ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
if inShort

    // TP1: price drops to/below TP1 level (short profit = price going down)
    // FIX v6.5.3-r3: removed barstate.isconfirmed for intrabar execution accuracy
    if not tp1hitShort and initialQtyShort > 0 and low <= tp1 and not partialClosedThisBar
        tp1hitShort          := true
        partialClosedThisBar := true

        strategy.cancel("Short_Full_Exit")
        strategy.cancel(ID_SHORT_TRAIL)
        strategy.cancel("Short_TP2_Exit")

        qtyToClose = actualFilledQty > 0 ? actualFilledQty : initialQtyShort

        strategy.close(ID_SHORT,
             qty     = qtyToClose * 0.50,
             comment = "TP1 50%")

        strategy.exit("Short_TP2_Exit", from_entry = ID_SHORT,
             qty_percent    = 30,
             stop           = currentDynamicSL,
             limit          = tp2,
             comment_profit = "TP2 30%",
             comment_loss   = "SL After TP1")

        strategy.exit(ID_SHORT_TRAIL, from_entry = ID_SHORT,
             qty_percent    = 20,
             stop           = currentDynamicSL,
             limit          = tp3,
             comment_profit = "TP3 Trail",
             comment_loss   = "SL TP3")

        if i_showLabels
            label.new(bar_index, low,
                 "‚úÖ TP1 HIT\n50% Closed",
                 color     = color.new(color.lime, 10),
                 textcolor = color.black,
                 style     = label.style_label_up,
                 size      = adaptiveSizeVal)

    // TP2: price drops to/below TP2 level, hanya setelah TP1 sudah terpicu
    // FIX v6.5.3-r3: removed barstate.isconfirmed for intrabar execution accuracy
    if not tp2hitShort and tp1hitShort and initialQtyShort > 0 and
         low <= tp2 and not partialClosedThisBar
        tp2hitShort          := true
        partialClosedThisBar := true

        qtyToClose = actualFilledQty > 0 ? actualFilledQty : initialQtyShort

        strategy.close(ID_SHORT,
             qty     = qtyToClose * 0.30,
             comment = "TP2 30%")

        strategy.exit(ID_SHORT_TRAIL, from_entry = ID_SHORT,
             qty_percent    = 20,
             stop           = currentDynamicSL,
             limit          = tp3,
             comment_profit = "TP3 After TP2",
             comment_loss   = "SL After TP2")

        if i_showLabels
            label.new(bar_index, low,
                 "‚úÖ TP2 HIT\n80% Closed",
                 color     = color.new(color.lime, 10),
                 textcolor = color.black,
                 style     = label.style_label_up,
                 size      = adaptiveSizeVal)


// ============================================================================
// SECTION 5.5: BREAKEVEN STATE
// ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
// Hitung state breakeven sebelum Section 6 dan Section 8 menggunakan variabel
// ini untuk rising-edge detection dan perbandingan time-series yang akurat.
breakevenActive = (inLong  and breakevenActiveLong) or
                  (inShort and breakevenActiveShort)

// ============================================================================
// SECTION 6: BREAKEVEN LOGIC
// ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
// Setelah TP1 hit: pindahkan SL ke entry price ‚Üí trade menjadi risk-free.
// Ini dieksekusi SETELAH partial close sehingga SL dinamis langsung ter-update
// untuk exit TP2 dan trail yang baru saja di-register di Section 5.
//
// Guard not breakevenActiveLong/Short: satu kali saja per posisi.
// prevDynamicSL di-reset ke na agar Section 7 (trail) segera re-register exit
// dengan SL breakeven yang baru.
// ============================================================================
if inLong and i_breakeven and tp1hitLong and not breakevenActiveLong
    currentDynamicSL    := entryPrice
    breakevenActiveLong := true
    prevDynamicSL       := na   // Force re-register exit dengan SL breakeven di Section 7

if inShort and i_breakeven and tp1hitShort and not breakevenActiveShort
    currentDynamicSL     := entryPrice
    breakevenActiveShort := true
    prevDynamicSL        := na   // Force re-register exit dengan SL breakeven di Section 7


// ============================================================================
// SECTION 7: TRAILING STOP UPDATE
// ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
// Trailing aktif setelah TP1 hit (jika i_trailingStop = true).
// Trail hanya ratchet searah posisi:
//   Long  : currentDynamicSL hanya naik  (math.max) ‚ÄĒ tidak pernah turun
//   Short : currentDynamicSL hanya turun (math.min) ‚ÄĒ tidak pernah naik
//
// Floor keamanan:
//   Long  : breakevenActiveLong  ? entryPrice : longSLPrice
//   Short : breakevenActiveShort ? entryPrice : shortSLPrice
//
// Saat trailing baru mulai (edge: tp1hitLong baru = true bar ini):
//   Cancel Long_Full_Exit yang di-register saat entry agar tidak bertumpuk
//   dengan exit dinamis baru yang akan di-register di Section 8.
// ============================================================================

// ‚ĒÄ‚ĒÄ LONG TRAILING ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
if inLong and i_trailingStop and tp1hitLong
    // Update trailing SL setiap bar setelah TP1 hit.
    newTrailL   = updateTrailLong(close)
    trailFloorL = breakevenActiveLong ? entryPrice : longSLPrice

    // Ratchet: SL hanya naik, tidak pernah turun (floor tambahan dari breakevenPrice)
    if not na(newTrailL)
        currentDynamicSL := math.max(currentDynamicSL,
             math.max(newTrailL, trailFloorL))

// ‚ĒÄ‚ĒÄ SHORT TRAILING ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
if inShort and i_trailingStop and tp1hitShort
    // Update trailing SL setiap bar setelah TP1 hit.
    newTrailS   = updateTrailShort(close)
    trailFloorS = breakevenActiveShort ? entryPrice : shortSLPrice

    // Ratchet: SL hanya turun, tidak pernah naik (floor dari shortSLPrice atau BE)
    if not na(newTrailS)
        currentDynamicSL := math.min(currentDynamicSL,
             math.min(newTrailS, trailFloorS))


// ============================================================================
// SECTION 8: DYNAMIC EXIT MANAGEMENT (SL/TP3 UPDATE)
// ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
// Re-register strategy.exit hanya saat SL atau TP3 berubah secara signifikan.
// Ini menghindari overhead memanggil strategy.exit() setiap bar (mahal di
// TradingView engine) sekaligus memastikan SL trail selalu ter-update.
//
// Threshold 0.1% (slUpdatePct): perubahan SL minimal sebelum re-register.
// Mencegah re-register berulang akibat floating point noise tick-by-tick.
//
// Guard tambahan:
//   not longClosedThisBar  / shortClosedThisBar  : posisi baru saja ditutup
//   not partialClosedThisBar                     : partial close baru terjadi
//   not enteredThisBar                           : entry baru terjadi
// ============================================================================

// Deteksi state posisi baru saja tertutup (transisi from_open ‚Üí flat bar ini)
// longJustClosed / shortJustClosed sudah dihitung di Section 4 ‚ÄĒ POSITION STATE
longClosedThisBar  = longJustClosed
shortClosedThisBar = shortJustClosed

// Reset state saat posisi baru saja tertutup (SL/TP terpicu oleh engine)
if longJustClosed or shortJustClosed
    prevDynamicSL    := na
    prevTp3          := na
    breakevenPrice   := na
    currentDynamicSL := na
    lastExitBar      := bar_index   // Update cooldown tracker (Grub 4)
    lastExitLongBar  := longJustClosed  ? bar_index : lastExitLongBar
    lastExitShortBar := shortJustClosed ? bar_index : lastExitShortBar
    exitHappenedThisBar := true

// Threshold signifikansi perubahan SL untuk re-register exit
slUpdatePct   = 0.001   // 0.1% ‚ÄĒ perubahan minimal yang dianggap bermakna
slUpdateMin   = math.max(atrVal * 0.25, syminfo.mintick)  // minimal pergerakan ATR untuk re-register
slSignificant = na(prevDynamicSL) ? true :
     (not na(currentDynamicSL) and
      (math.abs(currentDynamicSL - prevDynamicSL) /
       math.max(math.abs(prevDynamicSL), syminfo.mintick) >= slUpdatePct or
       math.abs(currentDynamicSL - prevDynamicSL) >= slUpdateMin))
slChanged           = slSignificant
tp3Changed          = na(prevTp3) or (not na(tp3) and tp3 != prevTp3)
breakevenJustActivated = breakevenActive and not prevBreakevenActive

// ‚ĒÄ‚ĒÄ LONG: Update trail + TP2 exit jika SL/TP3 berubah ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
if inLong and strategy.position_size > 0 and
     (slChanged or tp3Changed or breakevenJustActivated) and
     not longClosedThisBar and not enteredThisBar and
     (not partialClosedThisBar or breakevenJustActivated)

    // Update trailing exit untuk porsi TP3 (20%)
    strategy.exit(ID_LONG_TRAIL, from_entry = ID_LONG,
         qty_percent    = 20,
         stop           = currentDynamicSL,
         limit          = tp3,
         comment_profit = "TP3 Hit",
         comment_loss   = "SL Hit / Trailed")

    // Update exit TP2 (30%) jika TP2 belum terpicu (SL trail bergerak naik)
    if tp1hitLong and not tp2hitLong
        strategy.exit("Long_TP2_Exit", from_entry = ID_LONG,
             qty_percent    = 30,
             stop           = currentDynamicSL,
             limit          = tp2,
             comment_profit = "TP2 30%",
             comment_loss   = "SL Hit / Trailed (TP2)")

    prevDynamicSL := currentDynamicSL
    prevTp3       := tp3

// ‚ĒÄ‚ĒÄ SHORT: Update trail + TP2 exit jika SL/TP3 berubah ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
if inShort and strategy.position_size < 0 and
     (slChanged or tp3Changed or breakevenJustActivated) and
     not shortClosedThisBar and not enteredThisBar and
     (not partialClosedThisBar or breakevenJustActivated)

    strategy.exit(ID_SHORT_TRAIL, from_entry = ID_SHORT,
         qty_percent    = 20,
         stop           = currentDynamicSL,
         limit          = tp3,
         comment_profit = "TP3 Hit",
         comment_loss   = "SL Hit / Trailed")

    if tp1hitShort and not tp2hitShort
        strategy.exit("Short_TP2_Exit", from_entry = ID_SHORT,
             qty_percent    = 30,
             stop           = currentDynamicSL,
             limit          = tp2,
             comment_profit = "TP2 30%",
             comment_loss   = "SL Hit / Trailed (TP2)")

    prevDynamicSL := currentDynamicSL
    prevTp3       := tp3


// ============================================================================
// SECTION 9: REVERSAL EXIT (Signal-Based)
// ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
// Tutup posisi jika signal reversal terdeteksi.
// Ini adalah exit berbasis logika (bukan SL/TP price level).
//
// Guard:
//   not longClosedThisBar    : mencegah double-close di bar yang sama
//   not enteredThisBar       : mencegah close posisi yang baru dibuka bar ini
//   not longClosedByReversal : mencegah double-trigger dari Spot Exit (Section 4)
//
// Setelah close: cancel semua exit terdaftar agar tidak ada "zombie orders"
// yang bisa trigger setelah posisi sudah flat.
// ============================================================================

// ‚ĒÄ‚ĒÄ LONG REVERSAL EXIT ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
if exitLongSignal and not longClosedThisBar and not enteredThisBar and
     not longClosedByReversal

    strategy.close(ID_LONG, comment = "AE¬∑EXIT LONG | Signal reversal")
    strategy.cancel_all()

    longClosedByReversal := true
    lastExitBar          := bar_index
    lastExitLongBar      := bar_index
    exitHappenedThisBar  := true
    tp1hitLong           := false
    tp2hitLong           := false
    breakevenActiveLong  := false

    if i_showLabels
        label.new(bar_index, high, "EXIT LONG\nSignal reversal",
             color     = color.new(color.red, 10),
             textcolor = color.white,
             style     = label.style_label_down,
             size      = adaptiveSizeVal)

// ‚ĒÄ‚ĒÄ SHORT REVERSAL EXIT ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
if exitShortSignal and not shortClosedThisBar and not enteredThisBar and
     not shortClosedByReversal

    strategy.close(ID_SHORT, comment = "AE¬∑EXIT SHORT | Signal reversal")
    strategy.cancel_all()

    shortClosedByReversal := true
    lastExitBar           := bar_index
    lastExitShortBar      := bar_index
    exitHappenedThisBar   := true
    tp1hitShort           := false
    tp2hitShort           := false
    breakevenActiveShort  := false

    if i_showLabels
        label.new(bar_index, low, "EXIT SHORT\nSignal reversal",
             color     = color.new(color.lime, 15),
             textcolor = color.black,
             style     = label.style_label_up,
             size      = adaptiveSizeVal)


// ============================================================================
// SECTION 10: SMART EXIT (Ichimoku TK Filter)
// ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
// Lapisan exit tambahan berbasis Ichimoku Tenkan/Kijun cross.
// Lebih halus dari reversal exit: hanya aktif jika:
//   Long  : TK Death Cross terjadi DAN bearScore > bullScore (momentum sudah bergeser)
//   Short : TK Bullish Cross terjadi DAN bullScore > bearScore
//
// Ini mencegah exit terlalu dini hanya karena TK cross saja tanpa konfirmasi score.
// Guard identik dengan reversal exit untuk konsistensi.
// ============================================================================
smartExitLong  = inLong  and ichiTKDeath and bearScore > bullScore and not enteredThisBar
smartExitShort = inShort and ichiTKCross  and bullScore > bearScore and not enteredThisBar

if smartExitLong and not longClosedThisBar and not partialClosedThisBar and
     not longClosedByReversal

    strategy.close(ID_LONG, comment = "AE¬∑SMART EXIT LONG | TK Death")

    longClosedByReversal := true
    lastExitBar          := bar_index
    lastExitLongBar      := bar_index
    exitHappenedThisBar  := true

    if i_showLabels
        label.new(bar_index, high, "SMART EXIT L\nTK Death",
             color     = color.new(color.orange, 10),
             textcolor = color.white,
             style     = label.style_label_down,
             size      = adaptiveSizeVal)

if smartExitShort and not shortClosedThisBar and not partialClosedThisBar and
     not shortClosedByReversal

    strategy.close(ID_SHORT, comment = "AE¬∑SMART EXIT SHORT | TK Cross")

    shortClosedByReversal := true
    lastExitBar           := bar_index
    lastExitShortBar      := bar_index
    exitHappenedThisBar   := true

    if i_showLabels
        label.new(bar_index, low, "SMART EXIT S\nTK Cross",
             color     = color.new(color.teal, 10),
             textcolor = color.black,
             style     = label.style_label_up,
             size      = adaptiveSizeVal)


// ============================================================================
// SECTION 11: EXIT LABELS (SL/TP dari Engine)
// ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
// Buat label visual saat posisi ditutup oleh engine (SL/TP3 hit).
// longJustClosed / shortJustClosed sudah dihitung di Section 4.
// exitReason menggunakan state TP untuk menentukan konteks exit yang paling relevan.
// ============================================================================
if i_showLabels and longJustClosed
    exitReason = tp2hitLong ? "TP2/Final" : tp1hitLong ? "TP1 ‚Üí SL/TP3" : "SL Hit"
    label.new(bar_index, high,
         "EXIT LONG\n" + exitReason,
         color     = color.new(color.red, 10),
         textcolor = color.white,
         style     = label.style_label_down,
         size      = adaptiveSizeVal)

if i_showLabels and shortJustClosed
    exitReasonS = tp2hitShort ? "TP2/Final" : tp1hitShort ? "TP1 ‚Üí SL/TP3" : "SL Hit"
    label.new(bar_index, low,
         "EXIT SHORT\n" + exitReasonS,
         color     = color.new(color.lime, 15),
         textcolor = color.black,
         style     = label.style_label_up,
         size      = adaptiveSizeVal)


// ============================================================================
// SECTION 12: BREAKEVEN VISUAL LABEL
// ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
// Tampilkan label "ūüĒí BREAKEVEN ACTIVE" di chart saat breakeven sudah aktif.
// Hanya di-render di bar terakhir (barstate.islast) untuk performa.
// Label dihapus saat breakeven tidak lagi aktif.
// ============================================================================
// breakevenActive declared in Section 5.5 above ‚ÄĒ referenced here for label logic.

if breakevenActive and barstate.islast
    if not na(lblBreakeven)
        label.delete(lblBreakeven)
    lblBreakeven := label.new(bar_index, entryPrice,
         "ūüĒí BREAKEVEN ACTIVE",
         color     = color.new(color.yellow, 20),
         textcolor = color.black,
         style     = label.style_label_right,
         size      = size.small)

if not breakevenActive and not na(lblBreakeven)
    label.delete(lblBreakeven)
    lblBreakeven := na


// ============================================================================
// SECTION 13: PERSISTENT STATE SYNC (End of Bar)
// ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
// Update state tracker untuk edge-detection di Grub 8 (Alerts).
// WAJIB ditempatkan di akhir script setelah semua logika selesai dieksekusi,
// agar nilai "prev" merepresentasikan state bar ini yang akan dibandingkan
// dengan state bar berikutnya.
// ============================================================================
if barstate.isconfirmed
    prevBreakevenActive := breakevenActive
    prevLongHold        := longHold
    prevShortHold       := shortHold

// ============================================================================
// ‚Ėą‚Ėą‚ēó   ‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēó   ‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚ēó     ‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚Ėą‚ēó   ‚Ėą‚Ėą‚ēó
// ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēź‚ēź‚ēĚ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĎ     ‚Ėą‚Ėą‚ēĎ‚ēö‚ēź‚ēź‚ēź‚ēź‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēó‚ēö‚ēź‚ēź‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēĚ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēź‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚Ėą‚Ėą‚ēó  ‚Ėą‚Ėą‚ēĎ
// ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ     ‚Ėą‚Ėą‚ēĎ    ‚Ėą‚Ėą‚ēĒ‚ēĚ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĒ‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚ēĎ
// ‚ēö‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚ēĒ‚ēĚ‚Ėą‚Ėą‚ēĎ‚ēö‚ēź‚ēź‚ēź‚ēź‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ     ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĒ‚ēĚ ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ‚ēö‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĎ
//  ‚ēö‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĎ‚ēö‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ‚Ėą‚Ėą‚ēĎ  ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ  ‚Ėą‚Ėą‚ēĎ  ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ‚ēö‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ‚Ėą‚Ėą‚ēĎ ‚ēö‚Ėą‚Ėą‚Ėą‚Ėą‚ēĎ
//   ‚ēö‚ēź‚ēź‚ēź‚ēĚ  ‚ēö‚ēź‚ēĚ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ ‚ēö‚ēź‚ēĚ  ‚ēö‚ēź‚ēĚ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ‚ēö‚ēź‚ēĚ   ‚ēö‚ēź‚ēĚ  ‚ēö‚ēź‚ēĚ  ‚ēö‚ēź‚ēĚ   ‚ēö‚ēź‚ēĚ   ‚ēö‚ēź‚ēĚ ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ ‚ēö‚ēź‚ēĚ  ‚ēö‚ēź‚ēź‚ēź‚ēĚ
//  GRUB 6 ‚ÄĒ VISUALIZATION (v6.5.0 ‚ÄĒ Fixed, Upgraded, Perfected)
// ============================================================================
// CHANGELOG v6.5.0:
//   [FIX #1]  breakevenActive re-declaration removed ‚ÄĒ now reads from Strategy (Section 12).
//   [FIX #2]  prevBreakevenActive assignment removed ‚ÄĒ belongs exclusively to Grub 8 (Alerts).
//   [FIX #3]  lblBreakeven guard: uses Section 12's existing var label; no duplicate var declared here.
//   [FIX #4]  holdLabelCooldown declared as int constant (not re-allocated each bar).
//   [FIX #5]  Entry/Hold labels now use adaptiveSizeVal consistently (removed hardcoded size.normal/tiny).
//   [FIX #6]  TP/SL line extend offset is now adaptive to timeframe (not hardcoded 40).
//   [FIX #7]  Price precision in TP/SL labels now adaptive (syminfo.mintick-based).
//   [FIX #8]  BE line uses na-guard: only drawn when breakevenPrice is not na.
//   [FIX #9]  barcolor guarded by i_showLabels flag for user toggle control.
//   [FIX #10] remainingQty sync moved OUTSIDE the barstate.islast block ‚ÄĒ runs every bar.
//   [FIX #11] posSize na-guard: fallback to 0 when preview SL is na.
//   [FIX #12] rrDisplay full na-guard: handles na(entryPrice), na(tp2), na(currentDynamicSL).
//   [FIX #13] Dashboard variables (currentSL, tp1hit, tp2hit) guarded with proper na checks.
//   [FIX #14] Duplicate SECTION 12 / SECTION 13 logic fully removed from Grub 6.
//             All breakeven label logic lives exclusively in Strategy (Section 12).
//             All prevState updates live exclusively in Grub 8 (Alerts).
//   [UPGRADE] ENTRY LONG/SHORT labels: added score delta vs minConfl for context.
//   [UPGRADE] HOLD labels: replaced with barstate.isconfirmed guard to prevent realtime spam.
//   [UPGRADE] TP/SL line width more visually distinct (TP1=1, TP2=2, TP3=2, SL=3, BE=1 dotted).
//   [UPGRADE] SL line color now shifts to orange when breakeven is active (visual safety indicator).
//   [UPGRADE] Dashboard: added VWAP row (TC 1D auxiliary), cleaner separator rows, fixed column width.
//   [UPGRADE] Dashboard: posSize fallback shows "‚ÄĒ" cleanly; rrDisplay shows "‚ÄĒ" when no position.
// ============================================================================

// ‚ĒÄ‚ĒÄ ADAPTIVE HELPERS ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
// Adaptive line extension: how many bars forward to extend TP/SL lines.
// Higher TFs ‚Üí shorter visual extension (fewer bars per screen unit).
int lineExtend = timeframe.in_seconds() >= 86400  ? 10 :
                 timeframe.in_seconds() >= 14400  ? 20 :
                 timeframe.in_seconds() >= 3600   ? 30 : 40

// Adaptive price precision helper (syminfo.mintick-based decimal rounding).
// Prevents unnecessary trailing zeros on large-price assets (BTC at $65k etc.)
f_pricePrecision(float price) =>
    tick = syminfo.mintick
    tickDecimals = tick >= 1.0        ? 0 :
                   tick >= 0.1        ? 1 :
                   tick >= 0.01       ? 2 :
                   tick >= 0.001      ? 3 :
                   tick >= 0.0001     ? 4 :
                   tick >= 0.00001    ? 5 :
                   tick >= 0.000001   ? 6 :
                   tick >= 0.0000001  ? 7 : 8
    math.round(price, tickDecimals)


// ‚ĒÄ‚ĒÄ SIGNAL ENTRY LABELS ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
// [UPGRADED v6.5.0]
//   ‚ÄĘ Uses adaptiveSizeVal for size consistency across all timeframes.
//   ‚ÄĘ Added margin above minConfl for entry quality context (e.g. "+3 vs min").
//   ‚ÄĘ Protected by barstate.isconfirmed to eliminate realtime label duplication.

if i_showLabels and entryLongSignal and barstate.isconfirmed
    int scoreMargin = bullScore - minConfl
    label.new(bar_index, low,
         "‚Ė≤ ENTRY LONG [" + signalTier + "]\n" +
         str.tostring(bullScore) + " pts  +" + str.tostring(scoreMargin) + " vs min" +
         "\nRR " + str.tostring(math.round(tp2Mode, 1)) + "√ó",
         color     = color.new(color.lime, 5),
         textcolor = color.black,
         style     = label.style_label_up,
         size      = adaptiveSizeVal)

if i_showLabels and entryShortSignal and canShort and barstate.isconfirmed
    int scoreMarginS = bearScore - minConfl
    label.new(bar_index, high,
         "‚Ėľ ENTRY SHORT [" + signalTier + "]\n" +
         str.tostring(bearScore) + " pts  +" + str.tostring(scoreMarginS) + " vs min" +
         "\nRR " + str.tostring(math.round(tp2Mode, 1)) + "√ó",
         color     = color.new(color.red, 5),
         textcolor = color.white,
         style     = label.style_label_down,
         size      = adaptiveSizeVal)


// ‚ĒÄ‚ĒÄ HOLD LABELS ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
// [FIX v6.5.0]
//   ‚ÄĘ barstate.isconfirmed guard prevents realtime flicker/spam.
//   ‚ÄĘ Cooldown uses lastHoldLabelBar which is declared as var int in Strategy grub.
//   ‚ÄĘ Size uses adaptiveSizeVal for timeframe consistency.

int holdLabelCooldown = 5

bool showHoldLabel = na(lastHoldLabelBar) or (bar_index - lastHoldLabelBar > holdLabelCooldown)

if i_showLabels and longHold and not longCondition and showHoldLabel and barstate.isconfirmed
    label.new(bar_index, low,
         "‚óÜ HOLD L\n" + str.tostring(bullScore) + " pts",
         color     = color.new(color.teal, 40),
         textcolor = color.white,
         style     = label.style_label_up,
         size      = adaptiveSizeVal)
    lastHoldLabelBar := bar_index

if i_showLabels and shortHold and not shortCondition and showHoldLabel and barstate.isconfirmed
    label.new(bar_index, high,
         "‚óÜ HOLD S\n" + str.tostring(bearScore) + " pts",
         color     = color.new(color.orange, 40),
         textcolor = color.white,
         style     = label.style_label_down,
         size      = adaptiveSizeVal)
    lastHoldLabelBar := bar_index


// ‚ĒÄ‚ĒÄ TP/SL PERSISTENT LINES & LABELS ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
// [FIX v6.5.0]
//   ‚ÄĘ Persistent var objects declared once with var keyword.
//   ‚ÄĘ breakevenPrice na-guarded before BE line draw.
//   ‚ÄĘ SL line color shifts to orange when breakeven is active (visual safety cue).
//   ‚ÄĘ Line extension uses adaptive lineExtend instead of hardcoded 40.
//   ‚ÄĘ Label prices use f_pricePrecision() for clean adaptive decimal display.
//   ‚ÄĘ Full cleanup (delete + na) on position close to prevent ghost lines.

var line lineTP1 = na
var line lineTP2 = na
var line lineTP3 = na
var line lineSL  = na
var line lineBE  = na
var label lblTP1 = na
var label lblTP2 = na
var label lblTP3 = na
var label lblSL  = na
var label lblBE  = na

if barstate.islast or barstate.isrealtime
    if inLong or inShort
        float currentTp1 = tp1
        float currentTp2 = tp2
        float currentTp3 = tp3
        float currentSl  = currentDynamicSL
        float currentBe  = breakevenPrice

        // Determine SL line color: orange when breakeven is active (risk-free zone indicator)
        color slLineColor = breakevenActive ? color.new(color.orange, 20) : color.new(color.red, 20)

        // ‚ĒÄ‚ĒÄ TP1 line ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
        if not na(currentTp1)
            if na(lineTP1)
                lineTP1 := line.new(bar_index, currentTp1, bar_index + lineExtend, currentTp1,
                     color = color.new(color.lime, 30), style = line.style_dashed, width = 1)
            else
                line.set_xy1(lineTP1, bar_index, currentTp1)
                line.set_xy2(lineTP1, bar_index + lineExtend, currentTp1)
                line.set_color(lineTP1, color.new(color.lime, 30))
                line.set_width(lineTP1, 1)

        // ‚ĒÄ‚ĒÄ TP2 line ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
        if not na(currentTp2)
            if na(lineTP2)
                lineTP2 := line.new(bar_index, currentTp2, bar_index + lineExtend, currentTp2,
                     color = color.new(color.green, 20), style = line.style_dashed, width = 2)
            else
                line.set_xy1(lineTP2, bar_index, currentTp2)
                line.set_xy2(lineTP2, bar_index + lineExtend, currentTp2)
                line.set_color(lineTP2, color.new(color.green, 20))
                line.set_width(lineTP2, 2)

        // ‚ĒÄ‚ĒÄ TP3 line ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
        if not na(currentTp3)
            if na(lineTP3)
                lineTP3 := line.new(bar_index, currentTp3, bar_index + lineExtend, currentTp3,
                     color = color.new(color.teal, 10), style = line.style_dashed, width = 2)
            else
                line.set_xy1(lineTP3, bar_index, currentTp3)
                line.set_xy2(lineTP3, bar_index + lineExtend, currentTp3)
                line.set_color(lineTP3, color.new(color.teal, 10))
                line.set_width(lineTP3, 2)

        // ‚ĒÄ‚ĒÄ SL line ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
        if not na(currentSl)
            if na(lineSL)
                lineSL := line.new(bar_index, currentSl, bar_index + lineExtend, currentSl,
                     color = slLineColor, style = line.style_dashed, width = 3)
            else
                line.set_xy1(lineSL, bar_index, currentSl)
                line.set_xy2(lineSL, bar_index + lineExtend, currentSl)
                line.set_color(lineSL, slLineColor)
                line.set_width(lineSL, 3)

        // ‚ĒÄ‚ĒÄ BE line (only when breakevenPrice is valid) ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
        if not na(currentBe)
            if na(lineBE)
                lineBE := line.new(bar_index, currentBe, bar_index + lineExtend, currentBe,
                     color = color.new(color.yellow, 40), style = line.style_dotted, width = 1)
            else
                line.set_xy1(lineBE, bar_index, currentBe)
                line.set_xy2(lineBE, bar_index + lineExtend, currentBe)
                line.set_color(lineBE, color.new(color.yellow, 40))
                line.set_width(lineBE, 1)
        else if not na(lineBE)
            line.delete(lineBE)
            lineBE := na

        // ‚ĒÄ‚ĒÄ TP1 label ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
        if not na(currentTp1)
            string tp1Text = "TP1 50%  " + str.tostring(f_pricePrecision(currentTp1))
            if na(lblTP1)
                lblTP1 := label.new(bar_index + lineExtend, currentTp1, tp1Text,
                     color = color.new(color.lime, 20), textcolor = color.white,
                     style = label.style_label_left, size = size.small)
            else
                label.set_xy(lblTP1,   bar_index + lineExtend, currentTp1)
                label.set_text(lblTP1, tp1Text)

        // ‚ĒÄ‚ĒÄ TP2 label ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
        if not na(currentTp2)
            string tp2Text = "TP2 30%  " + str.tostring(f_pricePrecision(currentTp2))
            if na(lblTP2)
                lblTP2 := label.new(bar_index + lineExtend, currentTp2, tp2Text,
                     color = color.new(color.green, 20), textcolor = color.white,
                     style = label.style_label_left, size = size.small)
            else
                label.set_xy(lblTP2,   bar_index + lineExtend, currentTp2)
                label.set_text(lblTP2, tp2Text)

        // ‚ĒÄ‚ĒÄ TP3 label ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
        if not na(currentTp3)
            string tp3Text = "TP3 Trail  " + str.tostring(f_pricePrecision(currentTp3))
            if na(lblTP3)
                lblTP3 := label.new(bar_index + lineExtend, currentTp3, tp3Text,
                     color = color.new(color.teal, 20), textcolor = color.white,
                     style = label.style_label_left, size = size.small)
            else
                label.set_xy(lblTP3,   bar_index + lineExtend, currentTp3)
                label.set_text(lblTP3, tp3Text)

        // ‚ĒÄ‚ĒÄ SL label ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
        if not na(currentSl)
            string slText = (breakevenActive ? "SL (BE) " : "SL  ") + str.tostring(f_pricePrecision(currentSl))
            if na(lblSL)
                lblSL := label.new(bar_index + lineExtend, currentSl, slText,
                     color = slLineColor, textcolor = color.white,
                     style = label.style_label_left, size = size.small)
            else
                label.set_xy(lblSL,    bar_index + lineExtend, currentSl)
                label.set_text(lblSL,  slText)
                label.set_color(lblSL, slLineColor)

        // ‚ĒÄ‚ĒÄ BE label ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
        if not na(currentBe)
            if na(lblBE)
                lblBE := label.new(bar_index + lineExtend, currentBe, "BE Entry",
                     color = color.new(color.yellow, 30), textcolor = color.black,
                     style = label.style_label_left, size = size.tiny)
            else
                label.set_xy(lblBE, bar_index + lineExtend, currentBe)
        else if not na(lblBE)
            label.delete(lblBE)
            lblBE := na

    else
        // ‚ĒÄ‚ĒÄ No active position: clean up all persistent objects ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
        if not na(lineTP1)
            line.delete(lineTP1)
            lineTP1 := na
        if not na(lineTP2)
            line.delete(lineTP2)
            lineTP2 := na
        if not na(lineTP3)
            line.delete(lineTP3)
            lineTP3 := na
        if not na(lineSL)
            line.delete(lineSL)
            lineSL := na
        if not na(lineBE)
            line.delete(lineBE)
            lineBE := na
        if not na(lblTP1)
            label.delete(lblTP1)
            lblTP1 := na
        if not na(lblTP2)
            label.delete(lblTP2)
            lblTP2 := na
        if not na(lblTP3)
            label.delete(lblTP3)
            lblTP3 := na
        if not na(lblSL)
            label.delete(lblSL)
            lblSL := na
        if not na(lblBE)
            label.delete(lblBE)
            lblBE := na


// ‚ĒÄ‚ĒÄ CANDLE COLORING ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
// [FIX v6.5.0] Guarded by i_showLabels for user toggle control.
// Priority order: Entry signal > Hold signal > default (na = no override).
color candleColor = longCondition ? color.new(color.lime, 25) : shortCondition ? color.new(color.red, 25) : longHold ? color.new(color.teal, 55) : shortHold ? color.new(color.orange, 55) : na

barcolor(i_showLabels ? candleColor : na, title = "Signal Candle Color")


// ‚ĒÄ‚ĒÄ MTF BACKGROUND BIAS ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
// Teal tint = bullish MS + MTF aligned upward.
// Red tint  = bearish MS + MTF aligned downward.
// Kept very transparent (96) to avoid obstructing price action.
bgcolor(
     msBullish and mtfBullAlign ? color.new(color.teal, 96) :
     msBearish and mtfBearAlign ? color.new(color.red,  96) : na,
     title = "MTF Bias Background")


// ============================================================================
//  ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó  ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēó  ‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó  ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó  ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó
// ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēź‚ēź‚ēĚ‚Ėą‚Ėą‚ēĎ  ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēź‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēó
// ‚Ėą‚Ėą‚ēĎ  ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ‚Ėą‚Ėą‚ēĎ  ‚Ėą‚Ėą‚ēĎ
// ‚Ėą‚Ėą‚ēĎ  ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēĎ‚ēö‚ēź‚ēź‚ēź‚ēź‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĎ  ‚Ėą‚Ėą‚ēĎ
// ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ‚Ėą‚Ėą‚ēĎ  ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ  ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ‚ēö‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ‚Ėą‚Ėą‚ēĎ  ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ  ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ
// ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ ‚ēö‚ēź‚ēĚ  ‚ēö‚ēź‚ēĚ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ‚ēö‚ēź‚ēĚ  ‚ēö‚ēź‚ēĚ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ  ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ ‚ēö‚ēź‚ēĚ  ‚ēö‚ēź‚ēĚ‚ēö‚ēź‚ēĚ  ‚ēö‚ēź‚ēĚ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ
//  GRUB 7 ‚ÄĒ INFO DASHBOARD (v6.5.3-r2 ‚ÄĒ Final, Perfected, Bug-Free)
// ============================================================================
// [v6.5.1 Changelog]
//   ‚ÄĘ All string/color variables declared with explicit types outside table block
//   ‚ÄĘ remainingQty sync runs on every bar (not inside barstate.islast) ‚ÄĒ position size accuracy
//   ‚ÄĘ posSize: full na-guard chain, shows "‚ÄĒ" cleanly when no signal/position
//   ‚ÄĘ rrDisplay: full na-guard with math.abs protection against zero-division
//   ‚ÄĘ SL row bgcolor changes to orange when breakevenActive (visual feedback)
//   ‚ÄĘ f_pricePrecision() used for all price display (adaptive decimal rounding)
//   ‚ÄĘ sessionBG declared outside table block as typed color variable
//   ‚ÄĘ msBG declared outside table block as typed color variable
//   ‚ÄĘ htf1/2/3Display declared outside table block with explicit string type
//   ‚ÄĘ Performance stats all typed, closedTrades > 0 guard on winRate
//   ‚ÄĘ strategy.grossloss != 0.0 guard on profitFactor (no div by zero)
//   ‚ÄĘ Win rate color: green ‚Č•60%, yellow 45-59%, red <45%
//   ‚ÄĘ Profit factor color: green ‚Č•1.5, yellow 1.0-1.49, red <1.0
//   ‚ÄĘ table.new called only once via var + na(dash) guard (no duplicate creation)
//   ‚ÄĘ All 42 rows (0‚Äď41) fully accounted; row count matches table.new declaration
//   ‚ÄĘ Column 0: text_halign = text.align_right for clean key:value layout
//   ‚ÄĘ Version bumped to v6.5.3-r2
// ============================================================================

// ‚ĒÄ‚ĒÄ Sync remaining quantities EVERY bar for accurate position size display ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
remainingQtyLong  := inLong  ? math.max(0.0, strategy.position_size) : 0.0
remainingQtyShort := inShort ? math.abs(strategy.position_size)      : 0.0

// ‚ĒÄ‚ĒÄ Signal string & color ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
string currentSignal = longCondition ? "ūüĒ• BUY / LONG" : (shortCondition and canShort) ? "‚ĚĄÔłŹ SELL / SHORT" : longHold ? "ūüüĘ LONG HOLD" : (shortHold and canShort) ? "ūüĒī SHORT HOLD" : "‚ö™ NO SIGNAL"

color signalColor = longCondition ? color.new(color.lime, 5) : shortCondition ? color.new(color.red, 5) : longHold ? color.new(color.teal, 20) : shortHold ? color.new(color.orange, 20) : color.new(color.gray, 30)

// ‚ĒÄ‚ĒÄ Preview SL for position-size estimate before entry ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
float previewSLLong  = longCondition  and not na(temp_longSLPrice)  ? temp_longSLPrice  : na
float previewSLShort = shortCondition and not na(temp_shortSLPrice) ? temp_shortSLPrice : na

float posSize = (inLong or inShort) ? math.abs(strategy.position_size) : longCondition and not na(previewSLLong) ? calcPositionSize(close, previewSLLong) : shortCondition and not na(previewSLShort) ? calcPositionSize(close, previewSLShort) : 0.0

// ‚ĒÄ‚ĒÄ Risk:Reward display (dynamic or static fallback) ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
float rrDisplay = (not na(tp2) and not na(currentDynamicSL) and not na(entryPrice) and
                   math.abs(entryPrice - currentDynamicSL) > 0.0) ?
                  math.max(math.round(math.abs(tp2 - entryPrice) / math.abs(entryPrice - currentDynamicSL), 2), 0.1) :
                  math.round(tp2Mode, 2)

string dynBoostStr = i_dynamicRR ? "√ó" + str.tostring(math.round(dynRRBoost, 2)) + " vol" : "static"

// ‚ĒÄ‚ĒÄ HTF direction strings & colors ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
string htf1Str = htf1Bull ? "‚ÜĎ BULL" : htf1Bear ? "‚Üď BEAR" : "‚Üí NEUT"
string htf2Str = htf2Bull ? "‚ÜĎ BULL" : htf2Bear ? "‚Üď BEAR" : "‚Üí NEUT"
string htf3Str = htf3Bull ? "‚ÜĎ BULL" : htf3Bear ? "‚Üď BEAR" : "‚Üí NEUT"

color htf1Color = htf1Bull ? color.new(color.lime, 20) : htf1Bear ? color.new(color.red, 20) : color.new(color.gray, 30)
color htf2Color = htf2Bull ? color.new(color.lime, 20) : htf2Bear ? color.new(color.red, 20) : color.new(color.gray, 30)
color htf3Color = htf3Bull ? color.new(color.lime, 20) : htf3Bear ? color.new(color.red, 20) : color.new(color.gray, 30)

// ‚ĒÄ‚ĒÄ HTF display labels (auto-adapt or manual) ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
string htf1Display = i_autoAdapt ? (autoHTF1 + " ‚ö°") : i_htf1
string htf2Display = i_autoAdapt ? (autoHTF2 + " ‚ö°") : i_htf2
string htf3Display = i_autoAdapt ? (autoHTF3 + " ‚ö°") : i_htf3

// ‚ĒÄ‚ĒÄ Divergence string & color ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
string divStr = (divBullReg or divBullHid) ? "‚ÜĎ BULL DIV (" + str.tostring(divBullRegCount + divBullHidCount) + "/3)" : (divBearReg or divBearHid) ? "‚Üď BEAR DIV (" + str.tostring(divBearRegCount + divBearHidCount) + "/3)" : "No Div"
color divColor = (divBullReg or divBullHid) ? color.new(color.lime, 20) :
                 (divBearReg or divBearHid) ? color.new(color.red,  20) :
                 color.new(color.gray, 40)

// ‚ĒÄ‚ĒÄ FVG string & color ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
string fvgStr = fvgBullDetect ? "FVG‚ÜĎ Formed" : fvgBearDetect ? "FVG‚Üď Formed" : fvgBullScoreCapped > 0 ? "FVG‚ÜĎ Active" : fvgBearScoreCapped > 0 ? "FVG‚Üď Active" : "No FVG"
color fvgColor = fvgBullDetect or fvgBullScoreCapped > 0 ? color.new(color.lime, 30) :
                 fvgBearDetect or fvgBearScoreCapped > 0 ? color.new(color.red,  30) :
                 color.new(color.gray, 40)

// ‚ĒÄ‚ĒÄ Liquidity sweep string & color ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
string liqStr = liqSweepBullConf ? "ūüíß LIQ‚ÜĎ CONF" : liqSweepBearConf ? "ūüíß LIQ‚Üď CONF" : liqSweepBull ? "ūüíß LIQ‚ÜĎ" : liqSweepBear ? "ūüíß LIQ‚Üď" : "No Sweep"
color liqColor = liqSweepBull ? color.new(color.aqua,   20) :
                 liqSweepBear ? color.new(color.orange, 20) :
                 color.new(color.gray, 40)

// ‚ĒÄ‚ĒÄ Breakeven string & color ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
string beStr = breakevenActive and not na(breakevenPrice) ?
               "ūüĒí ACTIVE @ " + str.tostring(f_pricePrecision(breakevenPrice)) :
               breakevenActive ? "ūüĒí ACTIVE" : "Not Active"
color beColor = breakevenActive ? color.new(color.yellow, 10) : color.new(color.gray, 40)

// ‚ĒÄ‚ĒÄ HSNF string & color ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
string hsnfStr      = hsnfBull     ? "ūüüĘ BULL FLOW" :
                      hsnfBear     ? "ūüĒī BEAR FLOW" :
                      hsnfBullWeak ? "ūüü° WEAK BULL" :
                      hsnfBearWeak ? "ūüü° WEAK BEAR" : "‚ö™ NEUTRAL"
color hsnfDashColor = hsnfBull ? color.new(color.lime, 20) :
                      hsnfBear ? color.new(color.red,  20) :
                      color.new(color.gray, 30)

// ‚ĒÄ‚ĒÄ Auto S/R string & color ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
string srStr   = srNearResist  ? "‚ö†ÔłŹ NEAR RESIST"  : srNearSupport ? "‚úÖ NEAR SUPPORT" : "‚ÄĒ No Touch"
color  srDashC = srNearResist  ? color.new(color.red,  25) :
                 srNearSupport ? color.new(color.lime, 25) :
                 color.new(color.gray, 40)

// ‚ĒÄ‚ĒÄ TC 1D Volume string & color ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
string tc1dStr   = tc1dBull ? "ūüĒ• BULL VOLUME" : tc1dBear ? "ūüßä BEAR VOLUME" : "‚ÄĒ Neutral"
color  tc1dDashC = tc1dBull ? color.new(color.lime,   25) :
                   tc1dBear ? color.new(color.orange, 25) :
                   color.new(color.gray, 40)

// ‚ĒÄ‚ĒÄ Oscillator Matrix string & color ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
string oscStr   = oscBull ? "‚ö° BULL (" + str.tostring(oscBullCount) + "/3)" :
                  oscBear ? "‚ö° BEAR (" + str.tostring(oscBearCount) + "/3)" : "‚ÄĒ Mixed"
color  oscDashC = oscBull ? color.new(color.lime, 20) :
                  oscBear ? color.new(color.red,  20) :
                  color.new(color.gray, 40)

// ‚ĒÄ‚ĒÄ HTF Regime string & color ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
string domStr   = htfDominanceBull ? "ūüüĘ BULL DOM"  :
                  htfDominanceBear ? "ūüĒī BEAR DOM"  :
                  htfDivergence    ? "‚ö° DIVERGING" : "‚ö™ MIXED"
color  domColor = htfDominanceBull ? color.new(color.lime,   20) :
                  htfDominanceBear ? color.new(color.red,    20) :
                  htfDivergence    ? color.new(color.orange, 20) :
                  color.new(color.gray, 30)

// ‚ĒÄ‚ĒÄ Market Structure background color ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
color msBG = msBullish ? color.new(color.lime, 20) :
             msBearish ? color.new(color.red,  20) :
             color.new(color.gray, 30)

// ‚ĒÄ‚ĒÄ TP/SL bridge variables for dashboard ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
float currentSL = currentDynamicSL
bool  tp1hit    = inLong  ? tp1hitLong  : (inShort ? tp1hitShort  : false)
bool  tp2hit    = inLong  ? tp2hitLong  : (inShort ? tp2hitShort  : false)
bool  tp3hit    = false   // TP3 is a full-close event ‚ÄĒ no hanging "hit" state needed

// ‚ĒÄ‚ĒÄ Performance statistics ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
int   closedTrades   = strategy.closedtrades
float winRatePct     = closedTrades > 0        ? math.round((strategy.wintrades / strategy.closedtrades) * 100.0, 1) : na
float profitFactor   = strategy.grossloss != 0.0 ? math.round(strategy.grossprofit / math.abs(strategy.grossloss), 2) : na
float maxDD          = not na(strategy.max_drawdown) ? math.round(strategy.max_drawdown, 1) : na
float netProfit      = math.round(strategy.netprofit, 2)
string pfText        = not na(profitFactor)  ? str.tostring(profitFactor)          : "‚ÄĒ"
string maxDDText     = not na(maxDD)         ? str.tostring(maxDD) + "%"           : "‚ÄĒ"
string winRateText   = not na(winRatePct)    ? str.tostring(winRatePct) + "%"      : "‚ÄĒ"
string netProfitText = str.tostring(netProfit)

// ‚ĒÄ‚ĒÄ Win rate & profit factor adaptive colors ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
color winRateBG    = not na(winRatePct)   ? (winRatePct  >= 60.0 ? color.new(color.lime,  20) :
                                             winRatePct  >= 45.0 ? color.new(color.orange,20) :
                                             color.new(color.red, 20)) :
                     color.new(color.navy, 25)
color pfBG         = not na(profitFactor) ? (profitFactor >= 1.5  ? color.new(color.lime,  20) :
                                             profitFactor >= 1.0  ? color.new(color.orange,20) :
                                             color.new(color.red, 20)) :
                     color.new(color.navy, 25)

// ‚ĒÄ‚ĒÄ Session Detection (London + New York overlap & timezone awareness) ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
inLondonNYOverlap = inNewYork and inLondon  // Mon-Thu 13:00-17:00 UTC
sessionStr = inLondonNYOverlap ? "LON+NY ūüĒ•" : sessionName

color sessionBG = color.new(color.gray, 30)
if inLondonNYOverlap
    sessionBG := color.new(color.yellow, 95)
else if inNewYork
    sessionBG := color.new(color.purple, 20)
else if inLondon
    sessionBG := color.new(color.orange, 20)
else if inAsia
    sessionBG := color.new(color.blue, 20)

// ‚ĒÄ‚ĒÄ Dashboard table (lazy init ‚ÄĒ created only once per session) ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
var table dash = na

if i_showDashboard and (barstate.islast or barstate.isrealtime)
    if na(dash)
        dash := table.new(
             position     = position.top_right,
             columns      = 2,
             rows         = 43,
             bgcolor      = color.new(color.black, 5),
             border_color = color.new(color.gray,  30),
             border_width = 1,
             frame_color  = color.new(color.silver, 15),
             frame_width  = 2)

// ‚ĒÄ‚ĒÄ Dashboard rendering (safety-wrapped with not na(dash)) ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
if i_showDashboard and not na(dash)

    // ‚ĒÄ‚ĒÄ Row 0: Header ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
    table.cell(dash, 0, 0, "‚ö° AlphaEdge",
         bgcolor     = color.new(color.navy, 5),
         text_color  = color.white,
         text_size   = size.normal,
         text_halign = text.align_center)
    table.cell(dash, 1, 0, syminfo.tickerid + " ¬∑ " + timeframe.period,
         bgcolor     = color.new(color.navy, 5),
         text_color  = color.yellow,
         text_size   = size.small,
         text_halign = text.align_center)

    // ‚ĒÄ‚ĒÄ Row 1: Signal ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
    table.cell(dash, 0, 1, "SIGNAL",
         bgcolor     = color.new(color.black, 20),
         text_color  = color.silver,
         text_size   = size.small,
         text_halign = text.align_right)
    table.cell(dash, 1, 1, currentSignal,
         bgcolor    = signalColor,
         text_color = color.white,
         text_size  = size.normal)

    // ‚ĒÄ‚ĒÄ Row 2: Signal Tier ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
    table.cell(dash, 0, 2, "TIER",
         bgcolor     = color.new(color.black, 20),
         text_color  = color.silver,
         text_size   = size.small,
         text_halign = text.align_right)
    table.cell(dash, 1, 2, signalTier,
         bgcolor    = signalTierColor,
         text_color = color.black,
         text_size  = size.normal)

    // ‚ĒÄ‚ĒÄ Row 3: Position Status ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
    posStatus = inLong ? "IN LONG ‚Ė≤" : inShort ? "IN SHORT ‚Ėľ" : "‚ÄĒ FLAT"
    posStatusColor = inLong ? color.new(color.lime, 25) : inShort ? color.new(color.red, 25) : color.new(color.black, 40)
    table.cell(dash, 0, 3, "POSITION",
         bgcolor     = color.new(color.black, 20),
         text_color  = color.silver,
         text_size   = size.small,
         text_halign = text.align_right)
    table.cell(dash, 1, 3, posStatus,
         bgcolor    = posStatusColor,
         text_color = color.white,
         text_size  = size.normal)

    // ‚ĒÄ‚ĒÄ Row 4: Bull Score ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
    table.cell(dash, 0, 4, "BULL SCORE",
         bgcolor     = color.new(color.black, 30),
         text_color  = color.silver,
         text_size   = size.small,
         text_halign = text.align_right)
    table.cell(dash, 1, 4, str.tostring(bullScore) + " pts",
         bgcolor    = color.new(color.lime, 30),
